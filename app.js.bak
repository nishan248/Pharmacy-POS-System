// --- TAB SWITCHING ---
window.switchPurchasingTab = (tab) => {
    const btnPo = document.getElementById('tab-btn-po');
    const btnGrn = document.getElementById('tab-btn-grn');
    const secPo = document.getElementById('purchasing-po-section');
    const secGrn = document.getElementById('purchasing-grn-section');

    if (tab === 'po') {
        btnPo.className = "pb-2 px-4 text-sm font-semibold border-b-2 border-blue-600 text-blue-600";
        btnGrn.className = "pb-2 px-4 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700";
        secPo.classList.remove('hidden');
        secGrn.classList.add('hidden');
        loadPODashboard();
    } else {
        btnGrn.className = "pb-2 px-4 text-sm font-semibold border-b-2 border-blue-600 text-blue-600";
        btnPo.className = "pb-2 px-4 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700";
        secGrn.classList.remove('hidden');
        secPo.classList.add('hidden');
        loadGRNDashboard();
    }
};

// --- PURCHASE ORDERS LOGIC ---
let currentPOItems = [];
window.currentPOStatus = 'draft';

window.loadPODashboard = async () => {
    const tbody = document.getElementById('po-table-body');
    if(!tbody) return;
    tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4">Loading...</td></tr>';
    try {
        const pos = await db.purchase_orders.orderBy('id').reverse().toArray();
        if(pos.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4 text-gray-500">No Purchase Orders found.</td></tr>';
            return;
        }
        
        tbody.innerHTML = '';
        for(let po of pos) {
            const supplier = await db.suppliers.get(po.supplierId);
            const items = await db.po_items.where('poId').equals(po.id).toArray();
            const totalAmount = items.reduce((sum, item) => sum + item.total, 0);
            
            let statusBadge = '';
            if(po.status === 'draft') statusBadge = '<span class="px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs font-bold uppercase">Draft</span>';
            else if(po.status === 'sent') statusBadge = '<span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs font-bold uppercase">Sent</span>';
            else if(po.status === 'received') statusBadge = '<span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-bold uppercase">Received</span>';
            
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-medium text-blue-700">${po.poNumber}</td>
                    <td class="p-4 text-gray-600">${po.date}</td>
                    <td class="p-4 text-gray-600">${supplier ? supplier.name : 'Unknown'}</td>
                    <td class="p-4 text-right font-medium text-gray-800">${formatCurrency(totalAmount)}</td>
                    <td class="p-4 text-center">${statusBadge}</td>
                    <td class="p-4 text-center">
                        <button onclick="viewPO(${po.id})" class="text-blue-600 hover:text-blue-800 text-sm font-medium mr-2" title="View"><i class="fa-solid fa-eye"></i></button>
                        ${po.status === 'sent' ? `<button onclick="convertPOtoGRN(${po.id})" class="text-green-600 hover:text-green-800 text-sm font-medium mr-2" title="Convert to GRN"><i class="fa-solid fa-file-import"></i></button>` : ''}
                        <button onclick="printPO(${po.id})" class="text-gray-600 hover:text-gray-800 text-sm font-medium" title="Print"><i class="fa-solid fa-print"></i></button>
                    </td>
                </tr>
            `;
        }
    } catch(e) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4 text-red-500">Error loading POs</td></tr>';
        console.error(e);
    }
};

window.loadSuppliersSelect = async (elementId) => {
    const suppliers = await db.suppliers.toArray();
    const select = document.getElementById(elementId);
    if (!select) return;
    select.innerHTML = '<option value="">Select Supplier</option>';
    suppliers.forEach(s => {
        select.innerHTML += `<option value="${s.id}">${s.name}</option>`;
    });
};

window.openNewPOWizard = async () => {
    document.getElementById('po-dashboard-view').classList.add('hidden');
    document.getElementById('po-wizard-view').classList.remove('hidden');
    
    document.getElementById('po-wizard-title').innerText = 'New Purchase Order';
    document.getElementById('po-wizard-status').innerText = 'DRAFT';
    document.getElementById('po-wizard-status').className = 'px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs font-bold uppercase tracking-wider';
    
    document.getElementById('po-id').value = '';
    document.getElementById('po-no').value = 'PO-' + Date.now().toString().slice(-6);
    document.getElementById('po-date').value = new Date().toISOString().split('T')[0];
    
    await window.loadSuppliersSelect('po-supplier');
    
    currentPOItems = [];
    window.currentPOStatus = 'draft';
    renderPOItems();
    
    document.getElementById('btn-po-save').classList.remove('hidden');
    document.getElementById('btn-po-submit').classList.remove('hidden');
    document.getElementById('po-add-item-bar').classList.remove('hidden');
};

window.closePOWizard = () => {
    document.getElementById('po-dashboard-view').classList.remove('hidden');
    document.getElementById('po-wizard-view').classList.add('hidden');
    loadPODashboard();
};

window.renderPOItems = () => {
    const tbody = document.getElementById('po-items-tbody');
    let netTotal = 0;
    
    if(currentPOItems.length === 0) {
        tbody.innerHTML = '<tr id="po-empty-row"><td colspan="5" class="text-center p-6 text-gray-400">No items added to PO yet. Search and select above.</td></tr>';
        document.getElementById('po-net-total').innerText = formatCurrency(0);
        return;
    }
    
    tbody.innerHTML = '';
    currentPOItems.forEach(item => {
        netTotal += item.lineTotal;
        const disabled = window.currentPOStatus !== 'draft' ? 'disabled readonly' : '';
        const bgClass = window.currentPOStatus !== 'draft' ? 'bg-transparent border-0' : 'bg-white border-gray-300';
        
        let tags = '';
        if(item.isControlled) tags += '<span class="text-[10px] bg-red-100 text-red-700 px-1 py-0.5 rounded ml-2">Controlled</span>';
        if(item.isColdChain) tags += '<span class="text-[10px] bg-blue-100 text-blue-700 px-1 py-0.5 rounded ml-1">Cold Chain</span>';
        
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50 transition-colors">
                <td class="p-3">
                    <div class="font-medium text-sm text-gray-800">${item.brandName} ${tags}</div>
                </td>
                <td class="p-3">
                    <input type="number" min="0" class="w-full px-2 py-1 border rounded text-sm ${bgClass}" value="${item.qtyOrdered}" onchange="updatePOItem('${item.tempId}', 'qtyOrdered', this.value)" ${disabled}>
                </td>
                <td class="p-3">
                    <input type="number" min="0" step="0.01" class="w-full px-2 py-1 border rounded text-sm ${bgClass}" value="${item.unitCost}" onchange="updatePOItem('${item.tempId}', 'unitCost', this.value)" ${disabled}>
                </td>
                <td class="p-3 text-right font-medium text-gray-800">
                    ${formatCurrency(item.lineTotal)}
                </td>
                <td class="p-3 text-center">
                    ${window.currentPOStatus === 'draft' ? `<button onclick="removePOItem('${item.tempId}')" class="text-red-500 hover:text-red-700"><i class="fa-solid fa-trash"></i></button>` : '-'}
                </td>
            </tr>
        `;
    });
    
    document.getElementById('po-net-total').innerText = formatCurrency(netTotal);
};

window.addDrugToPO = (drug) => {
    const tempId = Date.now().toString() + Math.random().toString();
    currentPOItems.push({
        tempId: tempId,
        drugId: drug.id,
        brandName: drug.brandName,
        isControlled: drug.isControlled,
        isColdChain: drug.isColdChain,
        qtyOrdered: 0,
        unitCost: 0,
        lineTotal: 0
    });
    
    document.getElementById('po-item-search').value = '';
    document.getElementById('po-item-search-results').classList.add('hidden');
    renderPOItems();
    showToast('Item added to PO list', 'success');
};

window.updatePOItem = (tempId, field, value) => {
    if (window.currentPOStatus !== 'draft') return;
    const item = currentPOItems.find(i => i.tempId === tempId);
    if(item) {
        item[field] = parseFloat(value) || 0;
        item.lineTotal = item.qtyOrdered * item.unitCost;
        renderPOItems();
    }
};

window.removePOItem = (tempId) => {
    if (window.currentPOStatus !== 'draft') return;
    currentPOItems = currentPOItems.filter(i => i.tempId !== tempId);
    renderPOItems();
};

window.autoFillLowStockPO = async () => {
    const supplierIdStr = document.getElementById('po-supplier').value;
    if (!supplierIdStr) {
        return showToast('Please select a Supplier first to auto-fill items.', 'warning');
    }
    const supplierId = parseInt(supplierIdStr);

    try {
        const allDrugs = await db.drugs.toArray();
        const allBatches = await db.batches.toArray();
        
        const drugsForSupplier = new Set();
        allBatches.forEach(b => {
            if (b.supplierId === supplierId) {
                drugsForSupplier.add(b.drugId);
            }
        });

        let drugQtys = {};
        allDrugs.forEach(d => drugQtys[d.id] = 0);
        
        allBatches.forEach(b => {
            if (drugQtys[b.drugId] !== undefined) {
                drugQtys[b.drugId] += b.qty;
            } else {
                drugQtys[b.drugId] = b.qty;
            }
        });
        
        let addedCount = 0;
        
        for (const [dId, qty] of Object.entries(drugQtys)) {
            const drug = allDrugs.find(d => d.id == dId);
            if (!drug) continue;
            
            if (!drugsForSupplier.has(drug.id)) continue;

            const mbqThreshold = (drug.mbq !== undefined) ? drug.mbq : 20;
            
            if (qty <= mbqThreshold) {
                const existingItem = currentPOItems.find(item => item.drugId === drug.id);
                if (!existingItem) {
                    const latestBatch = allBatches.filter(b => b.drugId === drug.id).sort((a,b) => b.id - a.id)[0];
                    const estCost = latestBatch ? latestBatch.costPrice : 0;
                    const orderQty = (mbqThreshold * 2) - qty; // order enough to be double the MBQ, or adjust as needed. Simple default.
                    
                    const tempId = Date.now().toString() + addedCount;
                    currentPOItems.push({
                        tempId: tempId,
                        drugId: drug.id,
                        brandName: drug.brandName,
                        isControlled: drug.isControlled,
                        isColdChain: drug.isColdChain,
                        qtyOrdered: orderQty > 0 ? orderQty : mbqThreshold, // simple default quantity
                        unitCost: estCost,
                        lineTotal: (orderQty > 0 ? orderQty : mbqThreshold) * estCost
                    });
                    addedCount++;
                }
            }
        }
        
        if (addedCount > 0) {
            renderPOItems();
            showToast(`Added ${addedCount} low stock items for this supplier.`, 'success');
        } else {
            showToast('No low stock items found for the selected supplier.', 'info');
        }
    } catch (e) {
        console.error(e);
        showToast('Error auto-filling low stock items', 'error');
    }
};

window.savePO = async (status) => {
    const poIdStr = document.getElementById('po-id').value;
    const poNo = document.getElementById('po-no').value;
    const poDate = document.getElementById('po-date').value;
    const supplierId = parseInt(document.getElementById('po-supplier').value);
    
    if(!poDate || !supplierId) return showToast('Please fill all required fields', 'error');
    if(currentPOItems.length === 0) return showToast('Cannot save empty PO', 'error');
    
    for(let item of currentPOItems) {
        if(item.qtyOrdered <= 0) return showToast(`Invalid quantity for ${item.brandName}`, 'error');
    }
    
    try {
        const poData = {
            poNumber: poNo,
            date: poDate,
            supplierId: supplierId,
            status: status
        };
        
        let finalPoId;
        
        if(poIdStr) {
            finalPoId = parseInt(poIdStr);
            await db.purchase_orders.update(finalPoId, poData);
            await db.po_items.where('poId').equals(finalPoId).delete();
        } else {
            finalPoId = await db.purchase_orders.add(poData);
        }
        
        const itemsToSave = currentPOItems.map(i => {
            return {
                poId: finalPoId,
                drugId: i.drugId,
                qty: i.qtyOrdered,
                unitCost: i.unitCost,
                total: i.lineTotal
            };
        });
        
        await db.po_items.bulkAdd(itemsToSave);
        
        showToast(`Purchase Order ${status === 'draft' ? 'saved' : 'sent'} successfully`, 'success');
        closePOWizard();
    } catch(e) {
        showToast('Error saving PO', 'error');
        console.error(e);
    }
};

window.viewPO = async (id) => {
    try {
        const po = await db.purchase_orders.get(id);
        const items = await db.po_items.where('poId').equals(id).toArray();
        
        await openNewPOWizard();
        
        document.getElementById('po-wizard-title').innerText = 'View Purchase Order: ' + po.poNumber;
        document.getElementById('po-wizard-status').innerText = po.status.toUpperCase();
        
        if(po.status === 'draft') document.getElementById('po-wizard-status').className = 'px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs font-bold uppercase tracking-wider';
        else if(po.status === 'sent') document.getElementById('po-wizard-status').className = 'px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs font-bold uppercase tracking-wider';
        else if(po.status === 'received') document.getElementById('po-wizard-status').className = 'px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-bold uppercase tracking-wider';
        
        document.getElementById('po-id').value = po.id;
        document.getElementById('po-no').value = po.poNumber;
        document.getElementById('po-date').value = po.date;
        document.getElementById('po-supplier').value = po.supplierId;
        
        window.currentPOStatus = po.status;
        
        const allDrugs = await db.drugs.toArray();
        
        currentPOItems = items.map(i => {
            const d = allDrugs.find(dr => dr.id === i.drugId);
            return {
                tempId: Date.now().toString() + Math.random().toString(),
                drugId: i.drugId,
                brandName: d ? d.brandName : 'Unknown',
                isControlled: d ? d.isControlled : false,
                isColdChain: d ? d.isColdChain : false,
                qtyOrdered: i.qty,
                unitCost: i.unitCost,
                lineTotal: i.total
            };
        });
        
        renderPOItems();
        
        if(po.status !== 'draft') {
            document.getElementById('btn-po-save').classList.add('hidden');
            document.getElementById('btn-po-submit').classList.add('hidden');
            document.getElementById('po-add-item-bar').classList.add('hidden');
            document.getElementById('po-date').disabled = true;
            document.getElementById('po-supplier').disabled = true;
        } else {
            document.getElementById('po-date').disabled = false;
            document.getElementById('po-supplier').disabled = false;
        }
        
    } catch(e) {
        console.error(e);
        showToast('Error loading PO', 'error');
    }
};

window.printPO = async (id) => {
    try {
        const po = await db.purchase_orders.get(id);
        const items = await db.po_items.where('poId').equals(id).toArray();
        const supplier = await db.suppliers.get(po.supplierId);
        const total = items.reduce((sum, item) => sum + item.total, 0);
        
        const allDrugs = await db.drugs.toArray();
        
        let printWin = window.open('', '_blank');
        
        let html = `
            <html>
            <head>
                <title>Purchase Order ${po.poNumber}</title>
                <style>
                    body { font-family: Arial, sans-serif; padding: 40px; color: #333; }
                    .header { display: flex; justify-content: space-between; border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px; }
                    .title { font-size: 28px; font-weight: bold; color: #1e3a8a; }
                    .info-box { margin-bottom: 30px; display: flex; justify-content: space-between; }
                    .info-block { width: 45%; }
                    table { w-full; width: 100%; border-collapse: collapse; margin-bottom: 30px; }
                    th { background: #f3f4f6; text-align: left; padding: 12px; border-bottom: 2px solid #ddd; }
                    td { padding: 12px; border-bottom: 1px solid #eee; }
                    .text-right { text-align: right; }
                    .total { font-size: 20px; font-weight: bold; text-align: right; border-top: 2px solid #ddd; padding-top: 20px; }
                </style>
            </head>
            <body>
                <div class="header">
                    <div>
                        <div class="title">PURCHASE ORDER</div>
                        <div>PO Number: <strong>${po.poNumber}</strong></div>
                        <div>Date: ${po.date}</div>
                        <div>Status: ${po.status.toUpperCase()}</div>
                    </div>
                    <div style="text-align: right">
                        <div style="font-size: 20px; font-weight: bold;">Pharmacy POS System</div>
                        <div>123 Health Street</div>
                        <div>Colombo, Sri Lanka</div>
                    </div>
                </div>
                
                <div class="info-box">
                    <div class="info-block">
                        <div style="color: #666; margin-bottom: 5px;">Supplier Details:</div>
                        <div style="font-weight: bold; font-size: 16px;">${supplier ? supplier.name : 'Unknown'}</div>
                        <div>${supplier && supplier.phone ? supplier.phone : ''}</div>
                        <div>${supplier && supplier.email ? supplier.email : ''}</div>
                        <div>${supplier && supplier.address ? supplier.address : ''}</div>
                    </div>
                </div>
                
                <table>
                    <thead>
                        <tr>
                            <th>Item Description</th>
                            <th class="text-right">Qty</th>
                            <th class="text-right">Unit Cost</th>
                            <th class="text-right">Total</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        items.forEach(i => {
            const d = allDrugs.find(dr => dr.id === i.drugId);
            html += `
                <tr>
                    <td>${d ? d.brandName : 'Unknown Item'}</td>
                    <td class="text-right">${i.qty}</td>
                    <td class="text-right">${formatCurrency(i.unitCost)}</td>
                    <td class="text-right">${formatCurrency(i.total)}</td>
                </tr>
            `;
        });
        
        html += `
                    </tbody>
                </table>
                <div class="total">Total Amount: ${formatCurrency(total)}</div>
                <script>
                    window.onload = function() { window.print(); }
                </script>
            </body>
            </html>
        `;
        
        printWin.document.write(html);
        printWin.document.close();
    } catch(e) {
        console.error(e);
        showToast('Error printing PO', 'error');
    }
};

window.convertPOtoGRN = async (poId) => {
    try {
        const po = await db.purchase_orders.get(poId);
        if(!po) return;
        
        const poItems = await db.po_items.where('poId').equals(poId).toArray();
        const allDrugs = await db.drugs.toArray();
        
        switchPurchasingTab('grn');
        await openNewGRNWizard();
        
        document.getElementById('grn-supplier').value = po.supplierId;
        document.getElementById('grn-po').value = po.poNumber;
        
        currentGRNItems = poItems.map(i => {
            const d = allDrugs.find(dr => dr.id === i.drugId);
            return {
                tempId: Date.now().toString() + Math.random().toString(),
                drugId: i.drugId,
                brandName: d ? d.brandName : 'Unknown',
                isControlled: d ? d.isControlled : false,
                isColdChain: d ? d.isColdChain : false,
                batchNumber: '',
                expiryDate: '',
                qtyOrdered: i.qty,
                qtyReceived: i.qty, // Pre-fill received with ordered amount
                qtyFree: 0,
                qtyDamaged: 0,
                unitCost: i.unitCost,
                sellingPrice: 0,
                discountPerc: 0,
                taxPerc: 0,
                lineTotal: i.qty * i.unitCost,
                netAmount: i.qty * i.unitCost,
                qcStatus: 'Pass',
                temperature: '',
                licenseNo: ''
            };
        });
        
        renderGRNItems();
        showToast('GRN wizard pre-filled from PO', 'success');
        
    } catch(e) {
        console.error(e);
        showToast('Error converting PO to GRN', 'error');
    }
};

// PO Search Input logic
const poSearchInput = document.getElementById('po-item-search');
const poSearchResults = document.getElementById('po-item-search-results');

if (poSearchInput) {
    poSearchInput.addEventListener('input', async (e) => {
        const query = e.target.value.toLowerCase().trim();
        if(query.length < 2) {
            poSearchResults.classList.add('hidden');
            return;
        }
        try {
            const drugs = await db.drugs.toArray();
            const matches = drugs.filter(d => 
                d.brandName.toLowerCase().includes(query) || 
                (d.genericName && d.genericName.toLowerCase().includes(query))
            );
            
            poSearchResults.innerHTML = '';
            if(matches.length === 0) {
                poSearchResults.innerHTML = '<div class="p-3 text-sm text-gray-500">No drugs found.</div>';
            } else {
                matches.forEach(m => {
                    const div = document.createElement('div');
                    div.className = 'p-3 border-b border-gray-100 hover:bg-blue-50 cursor-pointer flex justify-between items-center';
                    let tags = '';
                    if(m.isControlled) tags += '<span class="text-[10px] bg-red-100 text-red-700 px-1 py-0.5 rounded ml-2">Controlled</span>';
                    if(m.isColdChain) tags += '<span class="text-[10px] bg-blue-100 text-blue-700 px-1 py-0.5 rounded ml-1">Cold Chain</span>';
                    
                    div.innerHTML = `<div><div class="font-medium text-sm text-gray-800">${m.brandName} ${tags}</div><div class="text-xs text-gray-500">${m.genericName || ''}</div></div><i class="fa-solid fa-plus text-blue-500"></i>`;
                    div.onclick = () => addDrugToPO(m);
                    poSearchResults.appendChild(div);
                });
            }
            poSearchResults.classList.remove('hidden');
        } catch(e) {
            console.error(e);
        }
    });
}

document.addEventListener('click', (e) => {
    if(poSearchInput && !poSearchInput.contains(e.target) && poSearchResults && !poSearchResults.contains(e.target)) {
        poSearchResults.classList.add('hidden');
    }
});


let currentGRNItems = [];

window.loadGRNDashboard = async () => {
    const tbody = document.getElementById('grn-table-body');
    if(!tbody) return;
    tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4">Loading...</td></tr>';
    try {
        const grns = await db.grn_header.orderBy('id').reverse().toArray();
        if(grns.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4 text-gray-500">No GRNs found.</td></tr>';
            return;
        }
        
        tbody.innerHTML = '';
        for(let grn of grns) {
            const supplier = await db.suppliers.get(grn.supplierId);
            const items = await db.grn_items.where('grnId').equals(grn.id).toArray();
            const netAmount = items.reduce((sum, item) => sum + item.netAmount, 0);
            
            let statusBadge = '';
            if(grn.status === 'draft') statusBadge = '<span class="px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs font-bold uppercase">Draft</span>';
            else if(grn.status === 'pending') statusBadge = '<span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded text-xs font-bold uppercase">Pending</span>';
            else if(grn.status === 'approved') statusBadge = '<span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-bold uppercase">Approved</span>';
            
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-medium text-blue-700">${grn.grnNo}</td>
                    <td class="p-4 text-gray-600">${grn.date}</td>
                    <td class="p-4 text-gray-600">${supplier ? supplier.name : 'Unknown'}</td>
                    <td class="p-4 text-right font-medium text-gray-800">${formatCurrency(netAmount)}</td>
                    <td class="p-4 text-center">${statusBadge}</td>
                    <td class="p-4 text-center">
                        <button onclick="viewGRN(${grn.id})" class="text-blue-600 hover:text-blue-800 text-sm font-medium mr-2" title="View"><i class="fa-solid fa-eye"></i></button>
                        <button onclick="printGRN(${grn.id})" class="text-gray-600 hover:text-gray-800 text-sm font-medium" title="Print"><i class="fa-solid fa-print"></i></button>
                    </td>
                </tr>
            `;
        }
    } catch(e) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4 text-red-500">Error loading GRNs</td></tr>';
        console.error(e);
    }
};

window.openNewGRNWizard = async () => {
    window.currentGRNStatus = 'draft';
    document.getElementById('grn-dashboard-view').classList.add('hidden');
    document.getElementById('grn-wizard-view').classList.remove('hidden');
    document.getElementById('grn-wizard-view').classList.add('flex');
    
    // Reset form
    document.getElementById('grn-id').value = '';
    document.getElementById('grn-date').value = new Date().toISOString().split('T')[0];
    document.getElementById('grn-invoice-no').value = '';
    document.getElementById('grn-po').value = '';
    
    document.getElementById('grn-date').disabled = false;
    document.getElementById('grn-supplier').disabled = false;
    document.getElementById('grn-invoice-no').readOnly = false;
    document.getElementById('grn-po').readOnly = false;
    document.getElementById('grn-received-by').readOnly = false;
    const addItemBar = document.getElementById('grn-add-item-bar');
    if (addItemBar) addItemBar.style.display = 'block';
    
    const currentUser = sessionStorage.getItem('currentUser');
    if(currentUser) {
        const user = JSON.parse(currentUser);
        document.getElementById('grn-received-by').value = user.fullName || user.username;
    } else {
        document.getElementById('grn-received-by').value = '';
    }
    
    document.getElementById('grn-wizard-status').innerText = 'Draft';
    document.getElementById('btn-grn-approve').classList.add('hidden');
    document.getElementById('btn-grn-save').classList.remove('hidden');
    document.getElementById('btn-grn-submit').classList.remove('hidden');
    
    currentGRNItems = [];
    renderGRNItems();
    
    // Generate GRN No
    try {
        const lastGRN = await db.grn_header.orderBy('id').last();
        let nextNo = 1;
        if(lastGRN && lastGRN.grnNo) {
            const matches = lastGRN.grnNo.match(/GRN-(\d+)/);
            if(matches) nextNo = parseInt(matches[1], 10) + 1;
        }
        document.getElementById('grn-no').value = 'GRN-' + nextNo.toString().padStart(5, '0');
    } catch(e) {
        document.getElementById('grn-no').value = 'GRN-00001';
    }
    
    // Load Suppliers
    const suppliers = await db.suppliers.toArray();
    const supSelect = document.getElementById('grn-supplier');
    supSelect.innerHTML = '<option value="">Select Supplier</option>';
    suppliers.forEach(s => {
        supSelect.innerHTML += `<option value="${s.id}">${s.name}</option>`;
    });
};

window.closeGRNWizard = () => {
    document.getElementById('grn-wizard-view').classList.add('hidden');
    document.getElementById('grn-wizard-view').classList.remove('flex');
    document.getElementById('grn-dashboard-view').classList.remove('hidden');
    loadGRNDashboard();
};

// GRN Item Search Logic Removed because items flow from PO.



window.addDrugToGRN = (drug) => {
    const tempId = Date.now().toString();
    currentGRNItems.push({
        tempId: tempId,
        drugId: drug.id,
        brandName: drug.brandName,
        isControlled: drug.isControlled,
        isColdChain: drug.isColdChain,
        batchNumber: '',
        expiryDate: '',
        qtyOrdered: 0,
        qtyReceived: 0,
        qtyFree: 0,
        qtyDamaged: 0,
        unitCost: 0,
        sellingPrice: 0,
        discountPerc: 0,
        taxPerc: 0,
        lineTotal: 0,
        netAmount: 0,
        qcStatus: 'Pass',
        temperature: '',
        licenseNo: ''
    });
    
    grnSearchInput.value = '';
    grnSearchResults.classList.add('hidden');
    renderGRNItems();
    showToast('Item added to GRN list', 'success');
};



window.updateGRNItem = (tempId, field, value) => {
    if (window.currentGRNStatus === 'approved') return;
    const item = currentGRNItems.find(i => i.tempId === tempId);
    if(item) {
        item[field] = value;
        
        if(['qtyReceived', 'unitCost', 'discountPerc', 'taxPerc'].includes(field)) {
            const qty = parseFloat(item.qtyReceived) || 0;
            const cost = parseFloat(item.unitCost) || 0;
            const disc = parseFloat(item.discountPerc) || 0;
            const tax = parseFloat(item.taxPerc) || 0;
            
            const lineTotal = qty * cost;
            const discAmt = lineTotal * (disc / 100);
            const taxAmt = (lineTotal - discAmt) * (tax / 100);
            const netAmount = lineTotal - discAmt + taxAmt;
            
            item.lineTotal = lineTotal;
            item.netAmount = netAmount;
        }
        
        if(['qtyReceived', 'unitCost', 'discountPerc', 'taxPerc'].includes(field)) {
            const row = document.getElementById(`grn-row-${tempId}`);
            if(row) {
                const ltDisp = row.querySelector('.grn-line-total-disp');
                if(ltDisp) ltDisp.innerText = formatCurrency(item.netAmount);
            }
            updateGRNTotals();
        }
    }
};

window.removeGRNItem = (tempId) => {
    if (window.currentGRNStatus === 'approved') return;
    currentGRNItems = currentGRNItems.filter(i => i.tempId !== tempId);
    renderGRNItems();
};

window.renderGRNItems = () => {
    const tbody = document.getElementById('grn-items-tbody');
    if(!tbody) return;
    if(currentGRNItems.length === 0) {
        tbody.innerHTML = '<tr id="grn-empty-row"><td colspan="10" class="text-center p-6 text-gray-400">No items added to GRN yet. Search and select above.</td></tr>';
        updateGRNTotals();
        return;
    }
    
    tbody.innerHTML = '';
    const isApproved = window.currentGRNStatus === 'approved';
    const dis = isApproved ? 'disabled' : '';
    const ro = isApproved ? 'readonly' : '';
    
    currentGRNItems.forEach(item => {
        let extraFields = '';
        if(item.isColdChain) {
            extraFields += `<input type="text" placeholder="Recv Temp °C" value="${item.temperature}" onchange="updateGRNItem('${item.tempId}', 'temperature', this.value)" class="w-full px-2 py-1 text-xs border border-blue-300 rounded mb-1 bg-blue-50 focus:outline-none focus:ring-1 focus:ring-blue-500" ${ro}>`;
        }
        if(item.isControlled) {
            extraFields += `<input type="text" placeholder="License/Auth No" value="${item.licenseNo}" onchange="updateGRNItem('${item.tempId}', 'licenseNo', this.value)" class="w-full px-2 py-1 text-xs border border-red-300 rounded mb-1 bg-red-50 focus:outline-none focus:ring-1 focus:ring-red-500" ${ro}>`;
        }
        
        const tr = document.createElement('tr');
        tr.id = `grn-row-${item.tempId}`;
        
        tr.innerHTML = `
            <td class="p-2">
                <div class="font-medium text-gray-800 text-sm">${item.brandName}</div>
                <div class="mt-1">
                    <select onchange="updateGRNItem('${item.tempId}', 'qcStatus', this.value)" class="w-full px-2 py-1 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 bg-gray-50" ${dis}>
                        <option value="Pass" ${item.qcStatus === 'Pass' ? 'selected' : ''}>QC: Pass</option>
                        <option value="Quarantine" ${item.qcStatus === 'Quarantine' ? 'selected' : ''}>QC: Quarantine</option>
                        <option value="Reject" ${item.qcStatus === 'Reject' ? 'selected' : ''}>QC: Reject</option>
                    </select>
                </div>
            </td>
            <td class="p-2">
                <input type="text" placeholder="Batch No" value="${item.batchNumber}" onchange="updateGRNItem('${item.tempId}', 'batchNumber', this.value)" class="w-full px-2 py-1 text-sm border border-gray-300 rounded mb-1 focus:outline-none focus:ring-1 focus:ring-blue-500" ${ro}>
                <input type="date" value="${item.expiryDate}" onchange="updateGRNItem('${item.tempId}', 'expiryDate', this.value)" class="w-full px-2 py-1 text-xs border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-blue-500" ${ro}>
            </td>
            <td class="p-2">
                <div class="flex gap-1 mb-1">
                    <input type="number" placeholder="Ord" value="${item.qtyOrdered || ''}" onchange="updateGRNItem('${item.tempId}', 'qtyOrdered', this.value)" class="w-1/3 px-1 py-1 text-xs border border-gray-300 rounded text-center focus:outline-none" ${ro}>
                    <input type="number" placeholder="Rec" value="${item.qtyReceived || ''}" onchange="updateGRNItem('${item.tempId}', 'qtyReceived', this.value)" class="w-1/3 px-1 py-1 text-xs border border-blue-400 bg-blue-50 rounded font-bold text-center focus:outline-none" ${ro}>
                    <input type="number" placeholder="Free" value="${item.qtyFree || ''}" onchange="updateGRNItem('${item.tempId}', 'qtyFree', this.value)" class="w-1/3 px-1 py-1 text-xs border border-green-300 rounded text-center focus:outline-none" ${ro}>
                </div>
            </td>
            <td class="p-2">
                <input type="number" placeholder="Dmg" value="${item.qtyDamaged || ''}" onchange="updateGRNItem('${item.tempId}', 'qtyDamaged', this.value)" class="w-full px-2 py-1 text-sm border border-orange-300 bg-orange-50 rounded focus:outline-none text-center" ${ro}>
            </td>
            <td class="p-2">
                <input type="number" step="0.01" placeholder="0.00" value="${item.unitCost || ''}" onchange="updateGRNItem('${item.tempId}', 'unitCost', this.value)" class="w-full px-2 py-1 text-sm border border-gray-300 rounded text-right focus:outline-none focus:ring-1 focus:ring-blue-500" ${ro}>
            </td>
            <td class="p-2">
                <input type="number" step="0.01" placeholder="0.00" value="${item.sellingPrice || ''}" onchange="updateGRNItem('${item.tempId}', 'sellingPrice', this.value)" class="w-full px-2 py-1 text-sm border border-green-300 rounded text-right focus:outline-none focus:ring-1 focus:ring-green-500 font-bold" ${ro}>
            </td>
            <td class="p-2">
                <div class="flex gap-1">
                    <input type="number" step="0.1" placeholder="D%" value="${item.discountPerc || ''}" onchange="updateGRNItem('${item.tempId}', 'discountPerc', this.value)" class="w-1/2 px-1 py-1 text-xs border border-gray-300 rounded text-center focus:outline-none" ${ro}>
                    <input type="number" step="0.1" placeholder="T%" value="${item.taxPerc || ''}" onchange="updateGRNItem('${item.tempId}', 'taxPerc', this.value)" class="w-1/2 px-1 py-1 text-xs border border-gray-300 rounded text-center focus:outline-none" ${ro}>
                </div>
            </td>
            <td class="p-2">
                ${extraFields || '<span class="text-xs text-gray-400">N/A</span>'}
            </td>
            <td class="p-2 text-right">
                <span class="font-bold text-blue-700 text-sm grn-line-total-disp">${formatCurrency(item.netAmount)}</span>
            </td>
            <td class="p-2 text-center">
                ${isApproved ? '' : `<button onclick="removeGRNItem('${item.tempId}')" class="text-red-400 hover:text-red-600"><i class="fa-solid fa-trash"></i></button>`}
            </td>
        `;
        tbody.appendChild(tr);
    });
    
    updateGRNTotals();
};

const updateGRNTotals = () => {
    let subtotal = 0;
    let totalTax = 0;
    let netTotal = 0;
    
    currentGRNItems.forEach(item => {
        const qty = parseFloat(item.qtyReceived) || 0;
        const cost = parseFloat(item.unitCost) || 0;
        const disc = parseFloat(item.discountPerc) || 0;
        const tax = parseFloat(item.taxPerc) || 0;
        
        const lineTotal = qty * cost;
        const discAmt = lineTotal * (disc / 100);
        const amtAfterDisc = lineTotal - discAmt;
        const taxAmt = amtAfterDisc * (tax / 100);
        
        subtotal += amtAfterDisc;
        totalTax += taxAmt;
        netTotal += (amtAfterDisc + taxAmt);
    });
    
    const subE = document.getElementById('grn-subtotal');
    if(subE) subE.innerText = formatCurrency(subtotal);
    const taxE = document.getElementById('grn-tax');
    if(taxE) taxE.innerText = formatCurrency(totalTax);
    const netE = document.getElementById('grn-net-total');
    if(netE) netE.innerText = formatCurrency(netTotal);
};

window.saveGRN = async (status) => {
    if(currentGRNItems.length === 0) return showToast('Cannot save empty GRN', 'error');
    
    const supplierId = parseInt(document.getElementById('grn-supplier').value);
    if(!supplierId) return showToast('Please select a supplier', 'error');
    
    const invoiceNo = document.getElementById('grn-invoice-no').value.trim();
    if(!invoiceNo) return showToast('Supplier Invoice No is required', 'error');
    
    for(let item of currentGRNItems) {
        if(!item.batchNumber) return showToast(`Batch Number required for ${item.brandName}`, 'error');
        if(!item.expiryDate) return showToast(`Expiry Date required for ${item.brandName}`, 'error');
        if(item.qtyReceived <= 0 && item.qcStatus !== 'Reject') return showToast(`Valid Received Qty required for ${item.brandName}`, 'error');
        if(item.unitCost <= 0) return showToast(`Unit Cost required for ${item.brandName}`, 'error');
        if(item.sellingPrice <= 0) return showToast(`Selling Price required for ${item.brandName}`, 'error');
        if(item.isColdChain && !item.temperature) return showToast(`Receiving Temperature required for Cold Chain drug: ${item.brandName}`, 'error');
        if(item.isControlled && !item.licenseNo) return showToast(`License/Auth Number required for Controlled drug: ${item.brandName}`, 'error');
    }
    
    const grnNo = document.getElementById('grn-no').value;
    const date = document.getElementById('grn-date').value;
    const poNo = document.getElementById('grn-po').value.trim();
    const receivedBy = document.getElementById('grn-received-by').value.trim();
    const existingId = document.getElementById('grn-id').value;
    
    try {
        let grnId;
        await db.transaction('rw', db.grn_header, db.grn_items, async () => {
            const headerData = { grnNo, date, supplierId, supplierInvoiceNo: invoiceNo, poNo, receivedBy, status };
            
            if(existingId) {
                grnId = parseInt(existingId);
                await db.grn_header.update(grnId, headerData);
                const oldItems = await db.grn_items.where('grnId').equals(grnId).toArray();
                const oldIds = oldItems.map(i => i.id);
                await db.grn_items.bulkDelete(oldIds);
            } else {
                grnId = await db.grn_header.add(headerData);
            }
            
            const itemsToSave = currentGRNItems.map(i => {
                const data = { ...i, grnId };
                delete data.tempId;
                return data;
            });
            await db.grn_items.bulkAdd(itemsToSave);
        });
        
        showToast(`GRN saved as ${status.toUpperCase()}`, 'success');
        closeGRNWizard();
    } catch(e) {
        showToast('Error saving GRN: ' + e.message, 'error');
        console.error(e);
    }
};

window.viewGRN = async (id) => {
    try {
        const grn = await db.grn_header.get(id);
        const items = await db.grn_items.where('grnId').equals(id).toArray();
        
        openNewGRNWizard();
        
        document.getElementById('grn-id').value = grn.id;
        document.getElementById('grn-no').value = grn.grnNo;
        document.getElementById('grn-date').value = grn.date;
        document.getElementById('grn-supplier').value = grn.supplierId;
        document.getElementById('grn-invoice-no').value = grn.supplierInvoiceNo || '';
        document.getElementById('grn-po').value = grn.poNo || '';
        document.getElementById('grn-received-by').value = grn.receivedBy || '';
        
        document.getElementById('grn-wizard-status').innerText = grn.status.toUpperCase();
        
        const isApproved = grn.status === 'approved';
        window.currentGRNStatus = grn.status;
        
        // Header Fields Readonly State
        document.getElementById('grn-date').disabled = isApproved;
        document.getElementById('grn-supplier').disabled = isApproved;
        document.getElementById('grn-invoice-no').readOnly = isApproved;
        document.getElementById('grn-po').readOnly = isApproved;
        document.getElementById('grn-received-by').readOnly = isApproved;
        
        const addItemBar = document.getElementById('grn-add-item-bar');
        if (addItemBar) addItemBar.style.display = isApproved ? 'none' : 'block';
        
        if(grn.status === 'pending') {
            document.getElementById('btn-grn-approve').classList.remove('hidden');
        } else {
            document.getElementById('btn-grn-approve').classList.add('hidden');
        }
        
        if(isApproved) {
            document.getElementById('btn-grn-save').classList.add('hidden');
            document.getElementById('btn-grn-submit').classList.add('hidden');
        } else {
            document.getElementById('btn-grn-save').classList.remove('hidden');
            document.getElementById('btn-grn-submit').classList.remove('hidden');
        }
        
        currentGRNItems = items.map(i => {
            return { ...i, tempId: Date.now().toString() + Math.random() };
        });
        
        renderGRNItems();
        
    } catch(e) {
        showToast('Error loading GRN', 'error');
    }
};

window.approveGRN = async () => {
    const grnId = parseInt(document.getElementById('grn-id').value);
    if(!grnId) return showToast('Save GRN first before approving', 'error');
    
    if(!confirm('Approving this GRN will update Inventory Stock Ledger and Accounts Payable. This action cannot be reversed. Proceed?')) return;
    
    try {
        await db.transaction('rw', db.grn_header, db.grn_items, db.batches, db.stock_ledger, db.accounts_payable, db.suppliers, db.purchase_orders, async () => {
            const grn = await db.grn_header.get(grnId);
            const items = await db.grn_items.where('grnId').equals(grnId).toArray();
            
            let totalPayable = 0;
            
            for(let item of items) {
                if(item.qcStatus === 'Pass') {
                    const actualQty = parseInt(item.qtyReceived) + parseInt(item.qtyFree);
                    if(actualQty > 0) {
                        const batchId = await db.batches.add({
                            drugId: item.drugId,
                            supplierId: grn.supplierId,
                            batchNumber: item.batchNumber,
                            expiryDate: item.expiryDate,
                            qty: actualQty,
                            costPrice: parseFloat(item.unitCost),
                            sellingPrice: parseFloat(item.sellingPrice)
                        });
                        
                        await db.stock_ledger.add({
                            date: new Date().toISOString(),
                            drugId: item.drugId,
                            batchId: batchId,
                            transactionType: 'GRN_RECEIPT',
                            qtyChange: actualQty,
                            reference: grn.grnNo
                        });
                    }
                }
                totalPayable += item.netAmount;
            }
            
            await db.accounts_payable.add({
                supplierId: grn.supplierId,
                grnId: grn.id,
                date: new Date().toISOString(),
                amount: totalPayable,
                status: 'pending'
            });
            
            // Update Supplier Dues
            const supplier = await db.suppliers.get(grn.supplierId);
            if(supplier) {
                await db.suppliers.update(grn.supplierId, { pendingDues: (supplier.pendingDues || 0) + totalPayable });
            }
            
            await db.grn_header.update(grnId, { status: 'approved' });
            
            if (grn.poNo) {
                const relatedPO = await db.purchase_orders.where('poNumber').equals(grn.poNo).first();
                if (relatedPO) {
                    await db.purchase_orders.update(relatedPO.id, { status: 'received' });
                }
            }
        });
        
        showToast('GRN Approved and Stock Updated!', 'success');
        closeGRNWizard();
        
        if(typeof loadInventory === 'function') loadInventory();
    } catch(e) {
        showToast('Error approving GRN: ' + e.message, 'error');
        console.error(e);
    }
};

window.printGRN = async (id) => {
    try {
        const grn = await db.grn_header.get(id);
        const items = await db.grn_items.where('grnId').equals(id).toArray();
        const supplier = await db.suppliers.get(grn.supplierId);
        const total = items.reduce((sum, item) => sum + item.netAmount, 0);
        
        const allDrugs = await db.drugs.toArray();
        
        let printWin = window.open('', '_blank');
        
        let html = `
            <html>
            <head>
                <title>Goods Received Note ${grn.grnNo}</title>
                <style>
                    body { font-family: Arial, sans-serif; padding: 40px; color: #333; }
                    .header { display: flex; justify-content: space-between; border-bottom: 2px solid #eee; padding-bottom: 20px; margin-bottom: 30px; }
                    .title { font-size: 28px; font-weight: bold; color: #1e3a8a; }
                    .info-box { margin-bottom: 30px; display: flex; justify-content: space-between; }
                    .info-block { width: 45%; }
                    table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
                    th { background: #f3f4f6; text-align: left; padding: 12px; border-bottom: 2px solid #ddd; }
                    td { padding: 12px; border-bottom: 1px solid #eee; }
                    .text-right { text-align: right; }
                    .total { font-size: 20px; font-weight: bold; text-align: right; border-top: 2px solid #ddd; padding-top: 20px; }
                </style>
            </head>
            <body>
                <div class="header">
                    <div>
                        <div class="title">GOODS RECEIVED NOTE</div>
                        <div>GRN Number: <strong>${grn.grnNo}</strong></div>
                        <div>Date: ${grn.date}</div>
                        <div>Status: ${grn.status.toUpperCase()}</div>
                    </div>
                    <div style="text-align: right">
                        <div style="font-size: 20px; font-weight: bold;">Pharmacy POS System</div>
                        <div>123 Health Street</div>
                        <div>Colombo, Sri Lanka</div>
                    </div>
                </div>
                
                <div class="info-box">
                    <div class="info-block">
                        <div style="color: #666; margin-bottom: 5px;">Supplier Details:</div>
                        <div style="font-weight: bold; font-size: 16px;">${supplier ? supplier.name : 'Unknown'}</div>
                        <div>${supplier && supplier.phone ? supplier.phone : ''}</div>
                        <div>${supplier && supplier.email ? supplier.email : ''}</div>
                        <div>${supplier && supplier.address ? supplier.address : ''}</div>
                    </div>
                    <div class="info-block" style="text-align: right;">
                        <div style="color: #666; margin-bottom: 5px;">Reference:</div>
                        <div>Invoice No: <strong>${grn.invoiceNo || '-'}</strong></div>
                        <div>PO Number: <strong>${grn.poNo || '-'}</strong></div>
                    </div>
                </div>
                
                <table>
                    <thead>
                        <tr>
                            <th>Item Description</th>
                            <th>Batch</th>
                            <th>Expiry</th>
                            <th class="text-right">Rcvd Qty</th>
                            <th class="text-right">Unit Cost</th>
                            <th class="text-right">Total</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        items.forEach(i => {
            const d = allDrugs.find(dr => dr.id === i.drugId);
            html += `
                <tr>
                    <td>${d ? d.brandName : 'Unknown Item'}</td>
                    <td>${i.batchNumber || '-'}</td>
                    <td>${i.expiryDate || '-'}</td>
                    <td class="text-right">${i.qtyReceived} ${i.qtyFree > 0 ? '(+'+i.qtyFree+' free)' : ''}</td>
                    <td class="text-right">${formatCurrency(i.unitCost)}</td>
                    <td class="text-right">${formatCurrency(i.netAmount)}</td>
                </tr>
            `;
        });
        
        html += `
                    </tbody>
                </table>
                <div class="total">Total Amount: ${formatCurrency(total)}</div>
                <script>
                    window.onload = function() { window.print(); }
                </script>
            </body>
            </html>
        `;
        
        printWin.document.write(html);
        printWin.document.close();
    } catch(e) {
        console.error(e);
        showToast('Error printing GRN', 'error');
    }
};

// ==========================================
// 9. AUTH & USER MANAGEMENT
// ==========================================

const checkAuth = async () => {
    try {
        const userCount = await db.users.count();
        if (userCount === 0) {
            await db.users.add({
                username: 'admin',
                password: 'admin123',
                role: 'Admin',
                fullName: 'System Administrator'
            });
        }
    } catch(e) {
        console.error("DB Initialization Error:", e);
    }

    const currentUser = sessionStorage.getItem('currentUser');
    if (!currentUser) {
        document.getElementById('login-screen').classList.remove('hidden');
        document.getElementById('app-wrapper').classList.add('hidden');
    } else {
        document.getElementById('login-screen').classList.add('hidden');
        document.getElementById('app-wrapper').classList.remove('hidden');
        
        const user = JSON.parse(currentUser);
        
        const topName = document.getElementById('top-user-name');
        if(topName) topName.innerText = user.fullName || user.username;
        const topRole = document.getElementById('top-user-role');
        if(topRole) topRole.innerText = user.role;
        
        const roleAccess = {
            'Admin': ['dashboard', 'pos', 'inventory', 'grn', 'reports', 'dayend', 'customers', 'suppliers', 'expiry', 'users', 'settings'],
            'Cashier': ['dashboard', 'pos', 'dayend', 'customers', 'settings'],
            'Pharmacist': ['dashboard', 'inventory', 'grn', 'reports', 'dayend', 'suppliers', 'expiry', 'settings']
        };

        const allowedTargets = roleAccess[user.role] || [];
        
        document.querySelectorAll('.nav-item').forEach(el => {
            const target = el.getAttribute('data-target');
            if (allowedTargets.includes(target)) {
                el.classList.remove('hidden');
                el.classList.add('flex');
            } else {
                el.classList.add('hidden');
                el.classList.remove('flex');
            }
        });
        
        loadDashboard();
        const targetEl = document.querySelector('.nav-item.active');
        if(targetEl && allowedTargets.includes(targetEl.getAttribute('data-target'))) {
            const target = targetEl.getAttribute('data-target');
            if(target === 'suppliers') loadSuppliers();
            if(target === 'customers') loadCustomers();
            if(target === 'expiry') loadExpiryManagement();
            if(target === 'grn') loadGRNDashboard();
            if(target === 'users' && user.role === 'Admin') loadUsers();
        } else if (allowedTargets.length > 0) {
            nav(allowedTargets[0]); // Default to first allowed target if current is not allowed
        }
        if(typeof loadPOSCustomers === 'function') loadPOSCustomers();
    }
};

window.handleLogin = async (e) => {
    e.preventDefault();
    const username = document.getElementById('login-username').value.trim();
    const password = document.getElementById('login-password').value;
    
    if(!username || !password) return showToast('Please enter both username and password', 'error');
    
    try {
        const user = await db.users.where('username').equals(username).first();
        
        if(!user || user.password !== password) {
            return showToast('Invalid credentials', 'error');
        }
        
        sessionStorage.setItem('currentUser', JSON.stringify({
            id: user.id,
            username: user.username,
            role: user.role,
            fullName: user.fullName
        }));
        
        document.getElementById('login-password').value = '';
        showToast('Login successful!', 'success');
        checkAuth();
    } catch(e) {
        showToast('Login error: ' + e.message, 'error');
    }
};

window.logout = () => {
    sessionStorage.removeItem('currentUser');
    document.getElementById('login-username').value = '';
    document.getElementById('login-password').value = '';
    showToast('Logged out successfully', 'info');
    
    setTimeout(() => {
        window.location.reload();
    }, 500);
};

// ==========================================
// DRUG PROFILE & LEDGER
// ==========================================
window.openDrugProfile = async (drugId) => {
    try {
        const drug = await db.drugs.get(drugId);
        if(!drug) return;

        document.getElementById('profile-drug-name').innerText = drug.brandName + (drug.dosage ? ` (${drug.dosage})` : '');
        document.getElementById('profile-drug-generic').innerText = drug.genericName || 'No Generic Name';

        // Load Batches
        const batches = await db.batches.where('drugId').equals(drug.id).toArray();
        const totalQty = batches.reduce((sum, b) => sum + b.qty, 0);
        document.getElementById('profile-total-stock').innerText = totalQty;

        const batchesTbody = document.getElementById('profile-batches-tbody');
        batchesTbody.innerHTML = '';
        if(batches.length === 0) {
            batchesTbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-gray-500">No active batches</td></tr>';
        } else {
            batches.forEach(b => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="p-3 text-gray-800 font-medium">${b.batchNumber}</td>
                    <td class="p-3 text-gray-600">${b.expiryDate}</td>
                    <td class="p-3 text-right font-bold text-gray-800">${b.qty}</td>
                    <td class="p-3 text-right text-gray-600">${formatCurrency(b.costPrice)}</td>
                    <td class="p-3 text-right text-blue-600 font-medium">${formatCurrency(b.sellingPrice)}</td>
                `;
                batchesTbody.appendChild(tr);
            });
        }

        // Load Ledger
        const ledgerTbody = document.getElementById('profile-ledger-tbody');
        ledgerTbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center">Loading ledger...</td></tr>';
        
        let ledgerEntries = await db.stock_ledger.where('drugId').equals(drug.id).toArray();
        ledgerEntries.sort((a,b) => new Date(b.date) - new Date(a.date)); // descending

        ledgerTbody.innerHTML = '';
        if(ledgerEntries.length === 0) {
            ledgerTbody.innerHTML = '<tr><td colspan="7" class="p-4 text-center text-gray-500">No transaction history found for this drug.</td></tr>';
        } else {
            for (const entry of ledgerEntries) {
                let batch = null;
                if (entry.batchId) {
                    batch = await db.batches.get(entry.batchId);
                }

                let unitPrice = 0;
                let batchInfo = entry.batchId || '-';
                
                if (batch) {
                    batchInfo = `${batch.batchNumber} (Exp: ${batch.expiryDate})`;
                    if (entry.transactionType === 'SALE' || entry.transactionType === 'RETURN') {
                        unitPrice = batch.sellingPrice;
                    } else {
                        unitPrice = batch.costPrice;
                    }
                }

                if (entry.transactionType === 'SALE' && entry.reference) {
                    const sale = await db.sales.where('invoiceNumber').equals(entry.reference).first();
                    if (sale) {
                        const saleItems = await db.salesItems.where('saleId').equals(sale.id).toArray();
                        const matchingItem = saleItems.find(i => i.drugId === drug.id && i.batchId === entry.batchId);
                        if (matchingItem) {
                            unitPrice = matchingItem.unitPrice;
                        }
                    }
                }
                
                let totalValue = Math.abs(entry.qtyChange) * unitPrice;

                let qtyClass = entry.qtyChange > 0 ? 'text-green-600' : (entry.qtyChange < 0 ? 'text-red-600' : 'text-gray-600');
                let qtyStr = entry.qtyChange > 0 ? '+' + entry.qtyChange : entry.qtyChange;
                
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-gray-50';
                tr.innerHTML = `
                    <td class="p-3 text-sm text-gray-600 whitespace-nowrap">${formatDate(entry.date)}</td>
                    <td class="p-3 text-sm text-gray-800 font-medium">${entry.transactionType}</td>
                    <td class="p-3 text-sm text-gray-600">${entry.reference || '-'}</td>
                    <td class="p-3 text-sm text-gray-500">${batchInfo}</td>
                    <td class="p-3 text-right text-sm text-gray-600">${unitPrice > 0 ? formatCurrency(unitPrice) : '-'}</td>
                    <td class="p-3 text-right text-sm font-bold ${qtyClass}">${qtyStr}</td>
                    <td class="p-3 text-right text-sm text-gray-800 font-medium">${totalValue > 0 ? formatCurrency(totalValue) : '-'}</td>
                `;
                ledgerTbody.appendChild(tr);
            }
        }

        switchProfileTab('batches');
        openModal('modal-drug-profile');
    } catch(e) {
        console.error(e);
        showToast('Error loading drug profile', 'error');
    }
};

window.switchProfileTab = (tab) => {
    document.getElementById('tab-content-batches').classList.add('hidden');
    document.getElementById('tab-content-ledger').classList.add('hidden');
    document.getElementById('tab-btn-batches').classList.replace('border-blue-600', 'border-transparent');
    document.getElementById('tab-btn-batches').classList.replace('text-blue-600', 'text-gray-500');
    document.getElementById('tab-btn-ledger').classList.replace('border-blue-600', 'border-transparent');
    document.getElementById('tab-btn-ledger').classList.replace('text-blue-600', 'text-gray-500');
    
    if (tab === 'batches') {
        document.getElementById('tab-content-batches').classList.remove('hidden');
        document.getElementById('tab-btn-batches').classList.replace('border-transparent', 'border-blue-600');
        document.getElementById('tab-btn-batches').classList.replace('text-gray-500', 'text-blue-600');
    } else {
        document.getElementById('tab-content-ledger').classList.remove('hidden');
        document.getElementById('tab-btn-ledger').classList.replace('border-transparent', 'border-blue-600');
        document.getElementById('tab-btn-ledger').classList.replace('text-gray-500', 'text-blue-600');
    }
};

