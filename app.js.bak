window.loadUsers = async () => {
    const tbody = document.getElementById('users-tbody');
    if(!tbody) return;
    
    try {
        const users = await db.users.toArray();
        tbody.innerHTML = '';
        
        if(users.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-gray-500">No users found.</td></tr>';
            return;
        }
        
        users.forEach(u => {
            let roleColor = 'gray';
            if(u.role === 'Admin') roleColor = 'blue';
            if(u.role === 'Pharmacist') roleColor = 'green';
            if(u.role === 'Cashier') roleColor = 'orange';
            
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-medium text-gray-800">${u.username}</td>
                    <td class="p-4 text-gray-600">${u.fullName || '-'}</td>
                    <td class="p-4"><span class="px-2 py-1 bg-${roleColor}-100 text-${roleColor}-700 rounded text-xs font-bold">${u.role}</span></td>
                    <td class="p-4 text-center">
                        <button onclick="deleteUser(${u.id})" class="text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 p-2 rounded transition-colors" title="Delete User"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            `;
        });
    } catch(e) {
        console.error(e);
    }
};

window.saveUser = async () => {
    const id = document.getElementById('user-id').value;
    const username = document.getElementById('user-username').value.trim();
    const password = document.getElementById('user-password').value;
    const fullName = document.getElementById('user-fullname').value.trim();
    const role = document.getElementById('user-role').value;
    
    if(!username || !password || !role) {
        return showToast('Required fields missing', 'error');
    }
    
    try {
        const existing = await db.users.where('username').equals(username).first();
        if(existing && existing.id.toString() !== id) {
            return showToast('Username already exists', 'error');
        }
        
        if(id) {
            await db.users.update(parseInt(id), { username, password, fullName, role });
            showToast('User updated successfully', 'success');
        } else {
            await db.users.add({ username, password, fullName, role });
            showToast('User created successfully', 'success');
        }
        
        closeModal('modal-add-user');
        document.getElementById('form-add-user').reset();
        document.getElementById('user-id').value = '';
        loadUsers();
    } catch(e) {
        showToast('Error saving user: ' + e.message, 'error');
    }
};

window.deleteUser = async (id) => {
    if(!confirm('Are you sure you want to delete this user?')) return;
    try {
        const user = await db.users.get(id);
        if(user && user.username === 'admin') {
            return showToast('Cannot delete the master admin account', 'error');
        }
        await db.users.delete(id);
        showToast('User deleted', 'success');
        loadUsers();
    } catch(e) {
        showToast('Error deleting user: ' + e.message, 'error');
    }
};



// ==========================================
// 10. DAY END CLOSING
// ==========================================
let currentDayEndTotals = { 
    expectedCash: 0, actualCash: 0, cashVariance: 0, 
    cardSales: 0, actualCard: 0, cardVariance: 0,
    creditSales: 0, totalSales: 0, cashIn: 0, cashOut: 0,
    floatLeft: 5000, cashDrop: 0, totalVariance: 0,
    denominations: {}
};

window.loadDayEndDashboard = async () => {
    try {
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('dayend-current-date').innerText = today;

        // 1. Fetch Sales for today (using safe local date parsing)
        const sales = await db.sales.toArray();
        const currentLocalDate = new Date().toLocaleDateString('en-CA'); // 'YYYY-MM-DD' locally
        
        const todaysSales = sales.filter(s => {
            if(!s.dateTime) return false;
            try {
                const saleDate = new Date(s.dateTime);
                if(isNaN(saleDate)) return false;
                return saleDate.toLocaleDateString('en-CA') === currentLocalDate;
            } catch(err) {
                return false;
            }
        });
        
        let cashIn = 0;
        let cardSales = 0;
        let creditSales = 0;
        
        todaysSales.forEach(s => {
            if(s.splitPayments && s.splitPayments.length > 0) {
                s.splitPayments.forEach(p => {
                    if(p.method === 'cash') cashIn += p.amount;
                    else if(p.method === 'card' || p.method === 'online') cardSales += p.amount;
                    else if(p.method === 'credit') creditSales += p.amount;
                });
            } else {
                if(s.paymentMethod === 'cash') cashIn += s.netAmount;
                else if(s.paymentMethod === 'card' || s.paymentMethod === 'online') cardSales += s.netAmount;
                else if(s.paymentMethod === 'credit') creditSales += s.netAmount;
            }
        });

        // 2. Fetch Cash Outflows for today (Supplier Payments)
        let cashOut = 0;
        if(db.supplier_payments) {
            const payments = await db.supplier_payments.toArray();
            const todaysPayments = payments.filter(p => {
                if(!p.date) return false;
                try {
                    const d = new Date(p.date);
                    if(isNaN(d)) return false;
                    return d.toLocaleDateString('en-CA') === currentLocalDate;
                } catch(err) {
                    return false;
                }
            });
            todaysPayments.forEach(p => {
                if(p.paymentMethod === 'cash') cashOut += p.amount;
            });
        }

        // 3. Calculate Totals
        const totalSales = cashIn + cardSales + creditSales;
        const expectedCash = cashIn - cashOut;

        currentDayEndTotals = { 
            expectedCash, actualCash: 0, cashVariance: -expectedCash, 
            cardSales, actualCard: 0, cardVariance: -cardSales,
            creditSales, totalSales, cashIn, cashOut,
            floatLeft: 5000, cashDrop: 0, totalVariance: -(expectedCash + cardSales),
            denominations: {}
        };

        // 4. Update UI
        document.getElementById('de-total-sales').innerText = formatCurrency(totalSales);
        document.getElementById('de-cash-in').innerText = formatCurrency(cashIn);
        document.getElementById('de-cash-out').innerText = '- ' + formatCurrency(cashOut);
        document.getElementById('de-expected-cash').innerText = formatCurrency(expectedCash);
        document.getElementById('de-expected-card').innerText = formatCurrency(cardSales);

        document.getElementById('de-actual-cash').value = '';
        document.getElementById('de-actual-card').value = '';
        document.getElementById('de-notes').value = '';
        document.getElementById('de-float').value = '5000';
        
        // Reset Denominations
        document.querySelectorAll('.de-float-denom-input, .de-drop-denom-input').forEach(input => {
            input.value = '';
        });
        document.querySelectorAll('.de-row-total').forEach(el => {
            el.innerText = '0';
        });

        calculateDayEndVariance();
        loadDayEndHistory();

    } catch (e) {
        console.error(e);
        showToast('Error loading Day End data', 'error');
    }
};

window.calculateDayEndVariance = () => {
    const actualStr = document.getElementById('de-actual-cash').value;
    const actualCash = parseFloat(actualStr) || 0;
    const cashVariance = actualCash - currentDayEndTotals.expectedCash;
    
    const actualCardStr = document.getElementById('de-actual-card').value;
    const actualCard = parseFloat(actualCardStr) || 0;
    const cardVariance = actualCard - currentDayEndTotals.cardSales;

    const floatStr = document.getElementById('de-float').value;
    const floatLeft = parseFloat(floatStr) || 0;
    const cashDrop = Math.max(0, actualCash - floatLeft);

    const totalVariance = cashVariance + cardVariance;

    currentDayEndTotals.actualCash = actualCash;
    currentDayEndTotals.cashVariance = cashVariance;
    currentDayEndTotals.actualCard = actualCard;
    currentDayEndTotals.cardVariance = cardVariance;
    currentDayEndTotals.floatLeft = floatLeft;
    currentDayEndTotals.cashDrop = cashDrop;
    currentDayEndTotals.totalVariance = totalVariance;

    // Update Cash Variance UI
    const cashVarianceEl = document.getElementById('de-cash-variance');
    cashVarianceEl.innerText = (cashVariance >= 0 ? '+ ' : '') + formatCurrency(cashVariance);
    cashVarianceEl.className = 'font-bold ' + (cashVariance < 0 ? 'text-red-600' : cashVariance > 0 ? 'text-green-600' : 'text-gray-800');

    // Update Card Variance UI
    const cardVarianceEl = document.getElementById('de-card-variance');
    const cardVarianceSumEl = document.getElementById('de-card-variance-summary');
    cardVarianceEl.innerText = (cardVariance >= 0 ? '+ ' : '') + formatCurrency(cardVariance);
    cardVarianceEl.className = 'font-bold ' + (cardVariance < 0 ? 'text-red-600' : cardVariance > 0 ? 'text-green-600' : 'text-gray-800');
    cardVarianceSumEl.innerText = cardVarianceEl.innerText;
    cardVarianceSumEl.className = cardVarianceEl.className;

    // Update Total Variance UI
    const totalVarianceEl = document.getElementById('de-total-variance');
    totalVarianceEl.innerText = (totalVariance >= 0 ? '+ ' : '') + formatCurrency(totalVariance);
    totalVarianceEl.className = 'font-bold text-lg ' + (totalVariance < 0 ? 'text-red-600' : totalVariance > 0 ? 'text-green-600' : 'text-gray-800');

    // Update Cash Drop UI
    document.getElementById('de-cash-drop').innerText = formatCurrency(cashDrop);
};

window.submitDayEnd = async () => {
    if(document.getElementById('de-actual-cash').value === '') {
        return showToast('Please enter the actual physical cash amount (or use the Denominations calculator).', 'error');
    }
    if(document.getElementById('de-actual-card').value === '') {
        return showToast('Please enter the actual card terminal batch total.', 'error');
    }

    if(!confirm('Are you sure you want to close the day? This will save the Z-Report.')) return;

    try {
        const record = {
            date: new Date().toISOString(),
            expectedCash: currentDayEndTotals.expectedCash,
            actualCash: currentDayEndTotals.actualCash,
            cashVariance: currentDayEndTotals.cashVariance,
            cardSales: currentDayEndTotals.cardSales,
            actualCard: currentDayEndTotals.actualCard,
            cardVariance: currentDayEndTotals.cardVariance,
            creditSales: currentDayEndTotals.creditSales,
            totalSales: currentDayEndTotals.totalSales,
            floatLeft: currentDayEndTotals.floatLeft,
            cashDrop: currentDayEndTotals.cashDrop,
            totalVariance: currentDayEndTotals.totalVariance,
            denominations: currentDayEndTotals.denominations,
            notes: document.getElementById('de-notes').value.trim(),
            performedBy: sessionStorage.getItem('currentUser') ? JSON.parse(sessionStorage.getItem('currentUser')).username : 'Unknown'
        };

        const id = await db.day_end_records.add(record);
        showToast('Day closed successfully!', 'success');
        
        loadDayEndHistory();
        printDayEndReport(id);
        
    } catch(e) {
        console.error(e);
        showToast('Error saving Day End record: ' + e.message, 'error');
    }
};

window.loadDayEndHistory = async () => {
    const tbody = document.getElementById('de-history-tbody');
    try {
        const records = await db.day_end_records.orderBy('id').reverse().limit(30).toArray();
        if(records.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-gray-500">No day end records found.</td></tr>';
            return;
        }

        tbody.innerHTML = '';
        records.forEach(r => {
            const tr = document.createElement('tr');
            
            // Handle backwards compatibility for variance
            let varianceDisplay = r.totalVariance !== undefined ? r.totalVariance : 
                                 (r.cashVariance !== undefined ? r.cashVariance : 
                                 (r.variance || 0));
                                 
            tr.innerHTML = `
                <td class="p-3 font-medium text-gray-800">${new Date(r.date).toLocaleString()}</td>
                <td class="p-3 text-right">${formatCurrency(r.expectedCash)}</td>
                <td class="p-3 text-right font-medium">${formatCurrency(r.actualCash)}</td>
                <td class="p-3 text-right ${varianceDisplay < 0 ? 'text-red-600' : varianceDisplay > 0 ? 'text-green-600' : 'text-gray-600'} font-bold">${formatCurrency(varianceDisplay)}</td>
                <td class="p-3 text-gray-600 text-xs">${r.notes || '-'}</td>
                <td class="p-3 text-center">
                    <button onclick="printDayEndReport(${r.id})" class="text-blue-600 hover:text-blue-800" title="Print Z-Report"><i class="fa-solid fa-print"></i></button>
                </td>
            `;
            tbody.appendChild(tr);
        });
    } catch(e) {
        console.error(e);
        tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-red-500">Error loading history.</td></tr>';
    }
};

window.printDayEndReport = async (id) => {
    try {
        const record = await db.day_end_records.get(id);
        if(!record) return showToast('Record not found', 'error');

        let printWin = window.open('', '_blank');
        
        let denomsHtml = '';
        if(record.denominations && Object.keys(record.denominations).length > 0) {
            denomsHtml = `<div class="border-bottom">
                <div class="center bold" style="margin-bottom:5px;">DENOMINATIONS</div>
                <div class="row" style="font-size: 10px; color: #555;">
                    <span style="width: 30%">Note</span>
                    <span style="width: 20%; text-align: right;">Float</span>
                    <span style="width: 20%; text-align: right;">Drop</span>
                    <span style="width: 30%; text-align: right;">Total</span>
                </div>`;
            for(let [val, data] of Object.entries(record.denominations)) {
                // Backwards compatibility for old records where data was just a number
                const count = typeof data === 'object' ? data.totalQty : data;
                const floatCount = typeof data === 'object' ? data.floatQty : '-';
                const dropCount = typeof data === 'object' ? data.dropQty : '-';
                
                if(count > 0) {
                    const label = val === '1' ? 'Coins' : `${val} x`;
                    denomsHtml += `
                    <div class="row" style="font-size: 12px;">
                        <span style="width: 30%">${label}</span>
                        <span style="width: 20%; text-align: right;">${floatCount}</span>
                        <span style="width: 20%; text-align: right;">${dropCount}</span>
                        <span style="width: 30%; text-align: right;">${formatCurrency(val * count).replace('Rs ','')}</span>
                    </div>`;
                }
            }
            denomsHtml += `</div>`;
        }

        let html = `
            <html>
            <head>
                <title>Z-Report - ${new Date(record.date).toLocaleDateString()}</title>
                <style>
                    body { font-family: 'Courier New', Courier, monospace; padding: 20px; color: #000; width: 300px; margin: 0 auto; }
                    .center { text-align: center; }
                    .bold { font-weight: bold; }
                    .border-bottom { border-bottom: 1px dashed #000; padding-bottom: 10px; margin-bottom: 10px; }
                    .row { display: flex; justify-content: space-between; margin-bottom: 5px; }
                    .title { font-size: 18px; margin-bottom: 5px; }
                </style>
            </head>
            <body>
                <div class="center border-bottom">
                    <div class="bold title">PHARMACY POS</div>
                    <div>123 Health Street</div>
                    <div>Daily Z-Report</div>
                </div>
                
                <div class="border-bottom">
                    <div class="row"><span>Date:</span> <span>${new Date(record.date).toLocaleString()}</span></div>
                    <div class="row"><span>User:</span> <span>${record.performedBy}</span></div>
                    <div class="row"><span>Record ID:</span> <span>#${record.id}</span></div>
                </div>

                <div class="border-bottom">
                    <div class="center bold" style="margin-bottom:10px;">SALES SUMMARY</div>
                    <div class="row"><span>Expected Cash:</span> <span>${formatCurrency(record.expectedCash)}</span></div>
                    <div class="row"><span>Expected Card:</span> <span>${formatCurrency(record.cardSales)}</span></div>
                    <div class="row"><span>Credit Sales:</span> <span>${formatCurrency(record.creditSales)}</span></div>
                    <div class="row bold" style="margin-top:5px;"><span>TOTAL SALES:</span> <span>${formatCurrency(record.totalSales)}</span></div>
                </div>

                <div class="border-bottom">
                    <div class="center bold" style="margin-bottom:10px;">CASH RECONCILIATION</div>
                    <div class="row"><span>Actual Cash Counted:</span> <span>${formatCurrency(record.actualCash)}</span></div>
                    <div class="row"><span>Cash Variance:</span> <span>${record.cashVariance >= 0 ? '+' : ''}${formatCurrency(record.cashVariance)}</span></div>
                    <div class="row" style="margin-top:5px;"><span>Float Left Next Day:</span> <span>${formatCurrency(record.floatLeft)}</span></div>
                    <div class="row bold"><span>CASH BANK DROP:</span> <span>${formatCurrency(record.cashDrop)}</span></div>
                </div>

                ${denomsHtml}

                <div class="border-bottom">
                    <div class="center bold" style="margin-bottom:10px;">CARD RECONCILIATION</div>
                    <div class="row"><span>Terminal Batch Total:</span> <span>${formatCurrency(record.actualCard || 0)}</span></div>
                    <div class="row"><span>Card Variance:</span> <span>${(record.cardVariance || 0) >= 0 ? '+' : ''}${formatCurrency(record.cardVariance || 0)}</span></div>
                </div>
                
                <div class="border-bottom">
                    <div class="row bold" style="font-size: 14px;">
                        <span>TOTAL NET VARIANCE:</span>
                        <span>${(record.totalVariance || 0) >= 0 ? '+' : ''}${formatCurrency(record.totalVariance || 0)}</span>
                    </div>
                </div>

                ${record.notes ? `
                <div class="border-bottom">
                    <div class="bold">Notes:</div>
                    <div style="font-size:12px; margin-top:5px;">${record.notes}</div>
                </div>
                ` : ''}

                <div class="center" style="margin-top: 20px; font-size: 12px;">
                    *** END OF REPORT ***
                </div>
                
                <script>
                    window.onload = function() { window.print(); }
                </script>
            </body>
            </html>
        `;
        
        printWin.document.write(html);
        printWin.document.close();
    } catch(e) {
        console.error(e);
        showToast('Error printing report', 'error');
    }
};

// INITIALIZE APP
window.onload = () => {
    checkAuth();
    
    // Bind Denomination Calculator Events
    const updateDenoms = () => {
        let totalFloat = 0;
        let totalDrop = 0;
        currentDayEndTotals.denominations = {};
        
        const rows = document.querySelectorAll('#de-denominations-container > .grid');
        rows.forEach(row => {
            const floatInput = row.querySelector('.de-float-denom-input');
            const dropInput = row.querySelector('.de-drop-denom-input');
            if(!floatInput || !dropInput) return;

            const val = parseInt(floatInput.getAttribute('data-val'));
            const floatQty = parseInt(floatInput.value) || 0;
            const dropQty = parseInt(dropInput.value) || 0;
            
            const totalQty = floatQty + dropQty;
            const rowTotal = val * totalQty;
            
            totalFloat += val * floatQty;
            totalDrop += val * dropQty;
            
            row.querySelector('.de-row-total').innerText = formatCurrency(rowTotal).replace('Rs ', '');
            
            if(totalQty > 0) {
                currentDayEndTotals.denominations[val] = {
                    floatQty, dropQty, totalQty
                };
            }
        });
        
        // Auto-fill actual cash and float
        document.getElementById('de-float').value = totalFloat || 0;
        document.getElementById('de-actual-cash').value = (totalFloat + totalDrop) || 0;
        calculateDayEndVariance();
    };

    document.querySelectorAll('.de-float-denom-input, .de-drop-denom-input').forEach(input => {
        input.addEventListener('input', updateDenoms);
    });
};

