            <th class="p-3 font-medium border-b border-gray-200 text-right">Revenue</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(filteredSales.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-gray-500">No prescriptions dispensed in this period.</td></tr>';
