const adjSearchInput = document.getElementById('adj-drug-search');
const adjSearchResults = document.getElementById('adj-drug-results');
const adjBatchSelect = document.getElementById('adj-batch-select');
const adjSystemQty = document.getElementById('adj-system-qty');
const adjNewQty = document.getElementById('adj-new-qty');
const adjSaveBtn = document.getElementById('adj-save-btn');

adjSearchInput?.addEventListener('input', async (e) => {
    const query = e.target.value.toLowerCase().trim();
    if(query.length < 2) {
        adjSearchResults.classList.add('hidden');
        return;
    }

    try {
        const drugs = await db.drugs.toArray();
        const matches = drugs.filter(d => 
            d.brandName.toLowerCase().includes(query) || 
            d.genericName.toLowerCase().includes(query)
        );

        adjSearchResults.innerHTML = '';
        if(matches.length === 0) {
            adjSearchResults.innerHTML = '<div class="p-2 text-gray-500 text-xs text-center">No drugs found</div>';
        } else {
            matches.forEach(d => {
                const div = document.createElement('div');
                div.className = 'p-2 border-b border-gray-100 hover:bg-orange-50 cursor-pointer text-sm';
                div.innerHTML = `<span class="font-medium text-gray-800">${d.brandName} ${d.dosage ? `(${d.dosage})` : ''}</span>`;
                div.onclick = () => selectAdjustmentDrug(d);
                adjSearchResults.appendChild(div);
            });
        }
        adjSearchResults.classList.remove('hidden');
    } catch(e) {}
});

document.addEventListener('click', (e) => {
    if(adjSearchInput && !adjSearchInput.contains(e.target) && !adjSearchResults.contains(e.target)) {
        adjSearchResults.classList.add('hidden');
    }
});

const selectAdjustmentDrug = async (drug) => {
    document.getElementById('adj-drug-id').value = drug.id;
    document.getElementById('adj-drug-name-disp').innerText = drug.brandName + (drug.dosage ? ` (${drug.dosage})` : '');
    
    adjSearchInput.value = '';
    adjSearchInput.classList.add('hidden');
    adjSearchResults.classList.add('hidden');
    document.getElementById('adj-selected-drug-info').classList.remove('hidden');
    
    // Load batches for this drug
    const batches = await db.batches.where('drugId').equals(drug.id).toArray();
    
    adjBatchSelect.disabled = false;
    if(batches.length > 0) {
        let html = '<option value="">-- Select Batch to Adjust --</option>';
        batches.sort((a,b) => new Date(a.expiryDate) - new Date(b.expiryDate)).forEach(b => {
            html += `<option value="${b.id}">${b.batchNumber} - Exp: ${b.expiryDate} (Current: ${b.qty})</option>`;
        });
        adjBatchSelect.innerHTML = html;
    } else {
        adjBatchSelect.innerHTML = '<option value="">No batches found for this drug</option>';
        adjBatchSelect.disabled = true;
    }
    
    adjSystemQty.value = '';
    adjNewQty.value = '';
    adjNewQty.disabled = true;
    adjSaveBtn.disabled = true;
};

window.clearAdjustmentDrug = () => {
    document.getElementById('adj-drug-id').value = '';
    document.getElementById('adj-selected-drug-info').classList.add('hidden');
    adjSearchInput.classList.remove('hidden');
    adjSearchInput.value = '';
    
    adjBatchSelect.innerHTML = '<option value="">-- Search and Select Drug First --</option>';
    adjBatchSelect.disabled = true;
    
    adjSystemQty.value = '';
    adjNewQty.value = '';
    adjNewQty.disabled = true;
    adjSaveBtn.disabled = true;
};

window.selectAdjustmentBatch = async () => {
    const batchIdStr = adjBatchSelect.value;
    if(!batchIdStr) {
        adjSystemQty.value = '';
        adjNewQty.value = '';
        adjNewQty.disabled = true;
        adjSaveBtn.disabled = true;
        return;
    }
    
    const batchId = parseInt(batchIdStr);
    const batch = await db.batches.get(batchId);
    
    if(batch) {
        adjSystemQty.value = batch.qty;
        adjNewQty.value = batch.qty;
        adjNewQty.disabled = false;
        adjSaveBtn.disabled = false;
        adjNewQty.focus();
        adjNewQty.select();
    }
};

window.saveStockAdjustment = async () => {
    const batchIdStr = adjBatchSelect.value;
    const newQtyStr = adjNewQty.value;
    
    if(!batchIdStr || newQtyStr === '') return;
    
    const batchId = parseInt(batchIdStr);
    const newQty = parseInt(newQtyStr);
    
    if(newQty < 0) return showToast('Quantity cannot be negative', 'error');
    
    try {
        await db.transaction('rw', db.batches, db.stock_ledger, async () => {
            const batch = await db.batches.get(batchId);
            const oldQty = batch.qty;
            await db.batches.update(batchId, { qty: newQty });
            
            await db.stock_ledger.add({
                date: new Date().toISOString(),
                drugId: batch.drugId,
                batchId: batch.id,
                transactionType: 'ADJUSTMENT',
                qtyChange: newQty - oldQty,
                reference: 'Manual Adjustment'
            });
        });
        showToast('Stock quantity updated successfully', 'success');
        closeModal('modal-stock-adjustment');
        
        // Reset modal form for next time
        clearAdjustmentDrug();
        
        // Refresh UI views if they are open
        loadInventory();
        loadDashboard();
        if(document.getElementById('pos').classList.contains('active')) {
            // If they happen to go to POS, maybe they need to re-search
        }
    } catch(e) {
        showToast('Error updating stock', 'error');
    }
};

// ==========================================
// 16. BILL RETURN LOGIC
// ==========================================

let currentReturnSale = null;
let currentReturnItems = [];

window.searchReturnBill = async () => {
    const invoiceNo = document.getElementById('return-invoice-no').value.trim().toUpperCase();
    if(!invoiceNo) return showToast('Please enter an invoice number', 'error');

    try {
        const sales = await db.sales.where('invoiceNumber').equals(invoiceNo).toArray();
        if(sales.length === 0) {
            return showToast('Invoice not found', 'error');
        }
        
        currentReturnSale = sales[0];
        document.getElementById('ret-sale-id').value = currentReturnSale.id;
        document.getElementById('ret-date').innerText = new Date(currentReturnSale.dateTime).toLocaleString();
        document.getElementById('ret-customer').innerText = currentReturnSale.customer || 'Walk-in';
        document.getElementById('ret-original-total').innerText = 'Rs. ' + parseFloat(currentReturnSale.totalAmount).toFixed(2);
        document.getElementById('ret-discount').innerText = 'Rs. ' + parseFloat(currentReturnSale.discount).toFixed(2);
        
        // Fetch items
        const items = await db.salesItems.where('saleId').equals(currentReturnSale.id).toArray();
        currentReturnItems = [];
        
        for(let item of items) {
            const drug = await db.drugs.get(item.drugId);
            const batch = await db.batches.get(item.batchId);
            currentReturnItems.push({
                ...item,
                drugName: drug ? drug.brandName + (drug.dosage ? ` ${drug.dosage}` : '') : 'Unknown Drug',
                batchNo: batch ? batch.batchNumber : 'Unknown Batch',
                returnQty: 0
            });
        }
        
        renderReturnItems();
        document.getElementById('return-bill-details').classList.remove('hidden');
        document.getElementById('return-bill-footer').classList.remove('hidden');
        calculateReturnRefund();
        
    } catch(e) {
        showToast('Error fetching invoice', 'error');
    }
};

window.renderReturnItems = () => {
    const tbody = document.getElementById('return-items-body');
    tbody.innerHTML = '';
    
    currentReturnItems.forEach((item, index) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td class="p-2">${item.drugName}</td>
            <td class="p-2"><span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-xs">${item.batchNo}</span></td>
            <td class="p-2 text-right">Rs. ${parseFloat(item.unitPrice).toFixed(2)}</td>
            <td class="p-2 text-center font-bold text-gray-700">${item.qty}</td>
            <td class="p-2 text-center">
                <input type="number" min="0" max="${item.qty}" value="${item.returnQty}" 
                    class="w-16 text-center border border-gray-300 rounded focus:ring-1 focus:ring-red-500"
                    onchange="updateReturnQty(${index}, this.value)">
            </td>
        `;
        tbody.appendChild(tr);
    });
};

window.updateReturnQty = (index, val) => {
    let qty = parseInt(val) || 0;
    if(qty < 0) qty = 0;
    if(qty > currentReturnItems[index].qty) qty = currentReturnItems[index].qty;
    
    currentReturnItems[index].returnQty = qty;
    renderReturnItems(); // re-render to enforce max/min in UI
    calculateReturnRefund();
};

window.calculateReturnRefund = () => {
    let refund = 0;
    currentReturnItems.forEach(item => {
        refund += item.returnQty * item.unitPrice;
    });
    
    // Pro-rate discount if applicable? For simplicity, we just refund based on unit price.
    // In a complex system, you might deduct a percentage of the total discount.
    document.getElementById('ret-refund-amount').innerText = 'Rs. ' + refund.toFixed(2);
};

window.processReturn = async () => {
    let hasReturns = currentReturnItems.some(item => item.returnQty > 0);
    if(!hasReturns) {
        return showToast('Please specify return quantities', 'error');
    }
    
    if(!confirm('Are you sure you want to process this return? This will update stock and sales records.')) return;
    
    try {
        await db.transaction('rw', db.sales, db.salesItems, db.batches, db.stock_ledger, async () => {
            let totalRefundAmount = 0;
            let totalRefundCost = 0;
            
            for(let item of currentReturnItems) {
                if(item.returnQty > 0) {
                    // Update Stock
                    const batch = await db.batches.get(item.batchId);
                    if(batch) {
                        await db.batches.update(item.batchId, { qty: batch.qty + item.returnQty });
                        
                        // Calculate cost refund for profit calculation adjustment
                        totalRefundCost += batch.costPrice * item.returnQty;
                        
                        await db.stock_ledger.add({
                            date: new Date().toISOString(),
                            drugId: item.drugId,
                            batchId: item.batchId,
                            transactionType: 'RETURN',
                            qtyChange: item.returnQty,
                            reference: 'Return ' + currentReturnSale.invoiceNumber
                        });
                    }
                    
                    // Update sales item record (reduce sold qty)
                    const newQty = item.qty - item.returnQty;
                    totalRefundAmount += item.returnQty * item.unitPrice;
                    
                    if(newQty === 0) {
                        // All items returned, we could delete it, but keeping it as 0 is better for history
                        await db.salesItems.update(item.id, { qty: 0, total: 0 });
                    } else {
                        await db.salesItems.update(item.id, { qty: newQty, total: newQty * item.unitPrice });
                    }
                }
            }
            
            // Adjust Sale Record
            const sale = await db.sales.get(currentReturnSale.id);
            const newTotalAmount = sale.totalAmount - totalRefundAmount;
            
            // Re-calculate discount proportionally if you want, but for now we keep the same discount amount 
            // unless the total drops below discount. Let's keep it simple: just reduce net amount.
            let newNet = sale.netAmount - totalRefundAmount;
            if(newNet < 0) newNet = 0;
            
            let newProfit = sale.profit - (totalRefundAmount - totalRefundCost);
            
            await db.sales.update(sale.id, {
                totalAmount: newTotalAmount,
                netAmount: newNet,
                profit: newProfit
            });
        });
        
        showToast('Bill returned successfully', 'success');
        closeModal('modal-return-bill');
        
        // Cleanup modal state
        document.getElementById('return-invoice-no').value = '';
        document.getElementById('return-bill-details').classList.add('hidden');
        document.getElementById('return-bill-footer').classList.add('hidden');
        currentReturnSale = null;
        currentReturnItems = [];
        
        // Refresh views
        loadDashboard();
        loadInventory();
        if(document.getElementById('reports').classList.contains('active')) {
            generateReport(); // Refresh reports if open
        }
        
    } catch(e) {
        showToast('Error processing return: ' + e.message, 'error');
    }
};

