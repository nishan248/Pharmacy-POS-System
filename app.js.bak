// 10. KEYBOARD SHORTCUTS
// ==========================================
document.addEventListener('keydown', (e) => {
    // F2: Focus Search in POS
    if(e.key === 'F2') {
        e.preventDefault();
        nav('pos');
        setTimeout(() => document.getElementById('pos-search').focus(), 100);
    }
    // F9: Checkout
    if(e.key === 'F9') {
        e.preventDefault();
        if(document.getElementById('pos').classList.contains('active')) {
            processCheckout();
        }
    }
});

// ==========================================
// 11. SUPPLIER MANAGEMENT
// ==========================================
window.currentSupplierId = null;

const saveSupplier = async () => {
    const id = document.getElementById('supp-id').value;
    const name = document.getElementById('supp-name').value.trim();
    const contactPerson = document.getElementById('supp-contact-person').value.trim();
    const phone = document.getElementById('supp-phone').value.trim();
    const email = document.getElementById('supp-email').value.trim();
    const paymentTerms = document.getElementById('supp-payment-terms').value;
    const address = document.getElementById('supp-address').value.trim();
    const pendingDues = parseFloat(document.getElementById('supp-dues').value) || 0;

    try {
        if(id) {
            await db.suppliers.update(parseInt(id), { name, contactPerson, phone, email, address, paymentTerms, pendingDues });
            showToast('Supplier updated successfully', 'success');
            if(window.currentSupplierId == id) viewSupplierDetails(parseInt(id)); // refresh detail view
        } else {
            await db.suppliers.add({ name, contactPerson, phone, email, address, paymentTerms, pendingDues });
            showToast('Supplier added successfully', 'success');
        }
        closeModal('modal-add-supplier');
        document.getElementById('form-add-supplier').reset();
        loadSuppliers();
    } catch(e) {
        showToast('Error saving supplier', 'error');
    }
};

const loadSuppliers = async () => {
    const search = document.getElementById('supp-search')?.value.toLowerCase() || '';
    const container = document.getElementById('suppliers-list-container');
    if(!container) return;

    try {
        let suppliers = await db.suppliers.toArray();
        if(search) {
            suppliers = suppliers.filter(s => s.name.toLowerCase().includes(search) || (s.contactPerson && s.contactPerson.toLowerCase().includes(search)));
        }

        container.innerHTML = '';
        if(suppliers.length === 0) {
            container.innerHTML = '<div class="p-5 text-center text-gray-500">No suppliers found.</div>';
            return;
        }

        suppliers.forEach(s => {
            const isActive = window.currentSupplierId === s.id ? 'bg-blue-50 border-blue-200' : 'hover:bg-gray-50 border-transparent border-b-gray-100';
            container.innerHTML += `
                <div id="supp-item-${s.id}" onclick="viewSupplierDetails(${s.id})" class="p-4 cursor-pointer border-b transition-colors supp-list-item ${isActive}">
                    <div class="flex justify-between items-start">
                        <div>
                            <h4 class="font-medium text-gray-800">${s.name}</h4>
                            <p class="text-xs text-gray-500 mt-1"><i class="fa-solid fa-user mr-1"></i> ${s.contactPerson || 'N/A'}</p>
                        </div>
                        <div class="text-right">
                            <span class="text-xs font-semibold text-red-600 block mb-1">${formatCurrency(s.pendingDues)}</span>
                        </div>
                    </div>
                </div>
            `;
        });
    } catch(e) {
        console.error(e);
    }
};

const editSupplier = async (id) => {
    const supplier = await db.suppliers.get(id);
    if(supplier) {
        document.getElementById('supp-id').value = supplier.id;
        document.getElementById('supp-name').value = supplier.name;
        document.getElementById('supp-contact-person').value = supplier.contactPerson || '';
        document.getElementById('supp-phone').value = supplier.phone;
        document.getElementById('supp-email').value = supplier.email;
        document.getElementById('supp-payment-terms').value = supplier.paymentTerms || 'Net 30 Days';
        document.getElementById('supp-address').value = supplier.address;
        document.getElementById('supp-dues').value = supplier.pendingDues;
        openModal('modal-add-supplier');
    }
};

const deleteSupplier = async (id) => {
    if(confirm('Delete this supplier?')) {
        await db.suppliers.delete(id);
        showToast('Supplier deleted', 'success');
        window.currentSupplierId = null;
        document.getElementById('supplier-empty-state').classList.remove('hidden');
        document.getElementById('supplier-detail-panel').classList.add('hidden');
        loadSuppliers();
    }
};

const switchSuppTab = (tabId) => {
    ['profile', 'ledger', 'purchases', 'returns'].forEach(t => {
        document.getElementById(`supp-view-${t}`).classList.add('hidden');
        document.getElementById(`supp-tab-${t}`).classList.remove('border-blue-600', 'text-blue-600');
        document.getElementById(`supp-tab-${t}`).classList.add('border-transparent', 'text-gray-500');
    });
    
    document.getElementById(`supp-view-${tabId}`).classList.remove('hidden');
    document.getElementById(`supp-tab-${tabId}`).classList.remove('border-transparent', 'text-gray-500');
    document.getElementById(`supp-tab-${tabId}`).classList.add('border-blue-600', 'text-blue-600');
    
    if(tabId === 'ledger') loadSupplierLedger(window.currentSupplierId);
    if(tabId === 'purchases') loadSupplierPurchases(window.currentSupplierId);
    if(tabId === 'returns') loadSupplierReturns(window.currentSupplierId);
};

const viewSupplierDetails = async (id) => {
    window.currentSupplierId = id;
    const supplier = await db.suppliers.get(id);
    if(!supplier) return;
    
    document.getElementById('supplier-empty-state').classList.add('hidden');
    document.getElementById('supplier-detail-panel').classList.remove('hidden');
    
    // Update active state in list
    document.querySelectorAll('.supp-list-item').forEach(el => el.classList.remove('bg-blue-50', 'border-blue-200', 'hover:bg-gray-50'));
    document.querySelectorAll('.supp-list-item').forEach(el => el.classList.add('hover:bg-gray-50'));
    document.getElementById(`supp-item-${id}`)?.classList.remove('hover:bg-gray-50');
    document.getElementById(`supp-item-${id}`)?.classList.add('bg-blue-50', 'border-blue-200');
    
    // Profile Header
    document.getElementById('supp-det-name').innerText = supplier.name;
    document.getElementById('supp-det-contact').innerText = supplier.contactPerson || 'N/A';
    document.getElementById('supp-det-dues').innerText = formatCurrency(supplier.pendingDues);
    
    // Profile Details
    document.getElementById('supp-det-phone').innerText = supplier.phone || 'N/A';
    document.getElementById('supp-det-email').innerText = supplier.email || 'N/A';
    document.getElementById('supp-det-address').innerText = supplier.address || 'N/A';
    document.getElementById('supp-det-terms').innerText = supplier.paymentTerms || 'N/A';
    
    switchSuppTab('profile');
};

const openSupplierPaymentModal = () => {
    if(!window.currentSupplierId) return;
    document.getElementById('form-supplier-payment').reset();
    openModal('modal-supplier-payment');
};

const processSupplierPayment = async () => {
    if(!window.currentSupplierId) return;
    const amount = parseFloat(document.getElementById('supp-pay-amount').value);
    const paymentMethod = document.getElementById('supp-pay-method').value;
    const reference = document.getElementById('supp-pay-ref').value.trim();

    if(amount <= 0) return showToast('Amount must be greater than 0', 'error');

    try {
        await db.transaction('rw', db.suppliers, db.supplier_payments, async () => {
            const supplier = await db.suppliers.get(window.currentSupplierId);
            if(!supplier) throw new Error("Supplier not found");

            // Create Payment Log
            await db.supplier_payments.add({
                date: new Date().toISOString(),
                supplierId: supplier.id,
                amount: amount,
                paymentMethod: paymentMethod,
                reference: reference,
                notes: 'Payment made'
            });

            // Update Supplier Dues
            const newDues = supplier.pendingDues - amount;
            await db.suppliers.update(supplier.id, { pendingDues: newDues });
        });

        showToast('Payment recorded successfully', 'success');
        closeModal('modal-supplier-payment');
        
        // Refresh UI
        loadSuppliers();
        viewSupplierDetails(window.currentSupplierId);
        if(!document.getElementById('supp-view-ledger').classList.contains('hidden')) {
            loadSupplierLedger(window.currentSupplierId);
        }
    } catch(e) {
        console.error(e);
        showToast('Error recording payment', 'error');
    }
};

const loadSupplierLedger = async (supplierId) => {
    const tbody = document.getElementById('supp-ledger-body');
    tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4">Loading...</td></tr>';
    
    try {
        // Fetch GRNs for Bills
        const grns = await db.grn_header.where('supplierId').equals(supplierId).and(g => g.status === 'approved').toArray();
        let grnLedger = [];
        for(let grn of grns) {
            const items = await db.grn_items.where('grnId').equals(grn.id).toArray();
            const netAmount = items.reduce((sum, item) => sum + item.netAmount, 0);
            grnLedger.push({
                date: grn.date,
                type: 'Bill (GRN)',
                reference: grn.grnNo,
                billAmount: netAmount,
                payAmount: 0
            });
        }
        
        // Fetch Payments
        const payments = await db.supplier_payments.where('supplierId').equals(supplierId).toArray();
        let payLedger = payments.map(p => ({
            date: p.date,
            type: `Payment (${p.paymentMethod})`,
            reference: p.reference || '-',
            billAmount: 0,
            payAmount: p.amount
        }));
        
        // Combine and Sort by Date
        const ledger = [...grnLedger, ...payLedger].sort((a, b) => new Date(a.date) - new Date(b.date));
        
        tbody.innerHTML = '';
        if(ledger.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-gray-500">No ledger entries found.</td></tr>';
            return;
        }
        
        ledger.forEach(l => {
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50">
                    <td class="p-3 whitespace-nowrap">${new Date(l.date).toLocaleDateString()}</td>
                    <td class="p-3">${l.type}</td>
                    <td class="p-3 text-gray-500">${l.reference}</td>
                    <td class="p-3 text-right font-medium text-red-600">${l.billAmount > 0 ? formatCurrency(l.billAmount) : '-'}</td>
                    <td class="p-3 text-right font-medium text-green-600">${l.payAmount > 0 ? formatCurrency(l.payAmount) : '-'}</td>
                </tr>
            `;
        });
        
    } catch(e) {
        console.error(e);
        tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-red-500">Error loading ledger.</td></tr>';
    }
};

const loadSupplierPurchases = async (supplierId) => {
    const tbody = document.getElementById('supp-purchases-body');
    tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4">Loading...</td></tr>';
    
    try {
        const grns = await db.grn_header.where('supplierId').equals(supplierId).toArray();
        grns.sort((a, b) => new Date(b.date) - new Date(a.date));
        
        tbody.innerHTML = '';
        if(grns.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-gray-500">No purchases found.</td></tr>';
            return;
        }
        
        for(let grn of grns) {
            const items = await db.grn_items.where('grnId').equals(grn.id).toArray();
            const netAmount = items.reduce((sum, item) => sum + item.netAmount, 0);
            
            let statusBadge = '';
            if(grn.status === 'draft') statusBadge = '<span class="px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs font-bold uppercase">Draft</span>';
            if(grn.status === 'approved') statusBadge = '<span class="px-2 py-1 bg-green-100 text-green-700 rounded text-xs font-bold uppercase">Approved</span>';
            
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50 cursor-pointer" onclick="viewGRN(${grn.id})">
                    <td class="p-3 whitespace-nowrap">${new Date(grn.date).toLocaleDateString()}</td>
                    <td class="p-3 font-medium text-blue-600">${grn.grnNo}</td>
                    <td class="p-3 text-center">${items.length}</td>
                    <td class="p-3 text-right font-bold text-gray-800">${formatCurrency(netAmount)}</td>
                    <td class="p-3 text-center">${statusBadge}</td>
                </tr>
            `;
        }
    } catch(e) {
        console.error(e);
        tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-red-500">Error loading purchases.</td></tr>';
    }
};

const loadSupplierReturns = async (supplierId) => {
    const tbody = document.getElementById('supp-returns-body');
    tbody.innerHTML = '<tr><td colspan="4" class="text-center p-4">Loading...</td></tr>';
    
    try {
        const returns = await db.disposals.filter(d => d.type === 'Return to Supplier').toArray();
        returns.sort((a, b) => new Date(b.date) - new Date(a.date));
        
        let supplierReturns = [];
        for(let ret of returns) {
            const batch = await db.batches.get(ret.batchId);
            const drug = await db.drugs.get(ret.drugId);
            
            // Fallback to drug's default supplier if batch didn't track it
            const retSupplierId = ret.supplierId || (batch ? batch.supplierId : null) || (drug ? drug.supplierId : null);
            
            if(retSupplierId == supplierId) {
                supplierReturns.push({
                    date: ret.date,
                    drugName: drug ? drug.brandName : 'Unknown',
                    batchNumber: batch ? batch.batchNumber : 'Unknown',
                    qty: ret.qty,
                    loss: ret.totalLoss
                });
            }
        }
        
        tbody.innerHTML = '';
        if(supplierReturns.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center p-4 text-gray-500">No returns found for this supplier.</td></tr>';
            return;
        }
        
        supplierReturns.forEach(ret => {
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50">
                    <td class="p-3 whitespace-nowrap">${new Date(ret.date).toLocaleDateString()}</td>
                    <td class="p-3">${ret.drugName} <span class="text-xs text-gray-500 ml-1">#${ret.batchNumber}</span></td>
                    <td class="p-3 text-center font-medium">${ret.qty}</td>
                    <td class="p-3 text-right font-medium text-red-600">${formatCurrency(ret.loss)}</td>
                </tr>
            `;
        });
        
    } catch(e) {
        console.error(e);
        tbody.innerHTML = '<tr><td colspan="4" class="text-center p-4 text-red-500">Error loading returns.</td></tr>';
    }
};

document.getElementById('supp-search')?.addEventListener('input', () => {
    clearTimeout(window.suppTimeout);
    window.suppTimeout = setTimeout(loadSuppliers, 300);
});

// ==========================================
// 12. CUSTOMER & PRESCRIPTION MANAGEMENT
// ==========================================
const saveCustomer = async () => {
    const id = document.getElementById('cust-id').value;
    const name = document.getElementById('cust-name').value.trim();
    const phone = document.getElementById('cust-phone').value.trim();
    const email = document.getElementById('cust-email').value.trim();
    const address = document.getElementById('cust-address').value.trim();
    const pin = document.getElementById('cust-pin').value.trim();
    const medicalNotes = document.getElementById('cust-notes').value.trim();

    try {
        if(id) {
            const updates = { name, phone, email, address, medicalNotes };
            if(pin) updates.pin = pin; // Only update pin if provided
            await db.customers.update(parseInt(id), updates);
            showToast('Customer updated', 'success');
            
            if(window.currentCustomerId === parseInt(id)) {
                viewCustomerDetails(parseInt(id)); // Refresh view
            }
        } else {
            await db.customers.add({ name, phone, email, address, medicalNotes, pin, loyaltyPoints: 0, storeCredit: 0 });
            showToast('Customer added', 'success');
        }
        closeModal('modal-add-customer');
        document.getElementById('form-add-customer').reset();
        loadCustomers();
        if(typeof loadPOSCustomers === 'function') loadPOSCustomers();
    } catch(e) {
        showToast('Error saving customer', 'error');
    }
};

const loadCustomers = async () => {
    const search = document.getElementById('cust-search')?.value.toLowerCase() || '';
    const container = document.getElementById('customers-list-container');
    if(!container) return;

    try {
        let customers = await db.customers.toArray();
        if(search) {
            customers = customers.filter(c => c.name.toLowerCase().includes(search) || c.phone.includes(search));
        }

        container.innerHTML = '';
        if(customers.length === 0) {
            container.innerHTML = '<div class="p-4 text-center text-gray-500 text-sm">No customers found.</div>';
            return;
        }

        customers.forEach(c => {
            const isActive = window.currentCustomerId === c.id ? 'bg-blue-50 border-l-4 border-blue-600' : 'hover:bg-gray-50 border-l-4 border-transparent';
            container.innerHTML += `
                <div onclick="viewCustomerDetails(${c.id})" class="p-4 border-b border-gray-100 cursor-pointer transition-colors ${isActive}">
                    <h3 class="font-bold text-gray-800">${c.name}</h3>
                    <div class="flex justify-between items-center mt-1">
                        <p class="text-xs text-gray-500"><i class="fa-solid fa-phone mr-1"></i> ${c.phone || 'N/A'}</p>
                        <span class="text-xs font-bold ${c.storeCredit > 0 ? 'text-green-600' : 'text-gray-400'}">Rs. ${formatCurrency(c.storeCredit || 0)}</span>
                    </div>
                </div>
            `;
        });
    } catch(e) {}
};

window.viewCustomerDetails = async (id) => {
    window.currentCustomerId = id;
    loadCustomers(); // refresh active state in list
    
    document.getElementById('customer-detail-panel').classList.remove('hidden');
    
    const customer = await db.customers.get(id);
    if(!customer) return;
    
    // Header
    document.getElementById('cust-det-name').innerText = customer.name;
    document.getElementById('cust-det-phone').innerText = customer.phone || 'No phone';
    document.getElementById('cust-det-credit').innerText = 'Rs. ' + formatCurrency(customer.storeCredit || 0);
    document.getElementById('cust-det-points').innerText = (customer.loyaltyPoints || 0) + ' pts';
    
    // Profile Tab
    document.getElementById('cust-det-address').innerText = customer.address || 'N/A';
    document.getElementById('cust-det-email').innerText = customer.email || 'N/A';
    document.getElementById('cust-det-pin-status').innerHTML = customer.pin ? '<span class="text-green-600 font-bold"><i class="fa-solid fa-check mr-1"></i> Set</span>' : '<span class="text-gray-400 italic">Not set</span>';
    
    // Default tab
    switchCustomerTab('profile');
};

window.switchCustomerTab = (tab) => {
    ['profile', 'purchases', 'prescriptions'].forEach(t => {
        document.getElementById(`cust-tab-${t}`).classList.remove('border-blue-600', 'text-blue-600');
        document.getElementById(`cust-tab-${t}`).classList.add('border-transparent', 'text-gray-500');
        document.getElementById(`cust-content-${t}`).classList.add('hidden');
    });
    
    document.getElementById(`cust-tab-${tab}`).classList.remove('border-transparent', 'text-gray-500');
    document.getElementById(`cust-tab-${tab}`).classList.add('border-blue-600', 'text-blue-600');
    document.getElementById(`cust-content-${tab}`).classList.remove('hidden');
    
    if(tab === 'profile') loadCustomerWallet(window.currentCustomerId);
    if(tab === 'purchases') loadCustomerPurchases(window.currentCustomerId);
    if(tab === 'prescriptions') loadCustomerPrescriptions(window.currentCustomerId);
};

window.editCustomerFromDetail = async () => {
    const customer = await db.customers.get(window.currentCustomerId);
    if(!customer) return;
    
    document.getElementById('cust-id').value = customer.id;
    document.getElementById('cust-name').value = customer.name;
    document.getElementById('cust-phone').value = customer.phone || '';
    document.getElementById('cust-email').value = customer.email || '';
    document.getElementById('cust-address').value = customer.address || '';
    document.getElementById('cust-notes').value = customer.medicalNotes || '';
    document.getElementById('cust-pin').value = ''; // Don't show existing pin
    document.getElementById('cust-pin').placeholder = customer.pin ? '(Hidden. Leave blank to keep current)' : 'e.g. 1234';
    
    openModal('modal-add-customer');
};

window.deleteCustomerFromDetail = async () => {
    if(confirm('Are you sure you want to delete this customer?')) {
        await db.customers.delete(window.currentCustomerId);
        document.getElementById('customer-detail-panel').classList.add('hidden');
        window.currentCustomerId = null;
        loadCustomers();
    }
};

const loadCustomerWallet = async (customerId) => {
    const tbody = document.getElementById('cust-wallet-ledger-body');
    tbody.innerHTML = '';
    
    const transactions = await db.wallet_transactions.where('customerId').equals(customerId).toArray();
    transactions.sort((a,b) => new Date(b.date) - new Date(a.date));
    
    if(transactions.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" class="text-center py-4 text-gray-400 italic">No wallet transactions</td></tr>';
        return;
    }
    
    transactions.forEach(t => {
        let typeBadge = '';
        let amountText = '';
        if(t.type === 'earn_points') { typeBadge = '<span class="text-blue-600 bg-blue-50 px-1 rounded">Earned Points</span>'; amountText = `+${t.amount} pts`; }
        if(t.type === 'redeem_points') { typeBadge = '<span class="text-red-600 bg-red-50 px-1 rounded">Redeemed Pts</span>'; amountText = `-${t.amount} pts`; }
        if(t.type === 'add_credit') { typeBadge = '<span class="text-green-600 bg-green-50 px-1 rounded">Credit Added</span>'; amountText = `+Rs. ${formatCurrency(t.amount)}`; }
        if(t.type === 'use_credit') { typeBadge = '<span class="text-orange-600 bg-orange-50 px-1 rounded">Credit Used</span>'; amountText = `-Rs. ${formatCurrency(t.amount)}`; }
        
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="py-2 text-gray-500">${new Date(t.date).toLocaleDateString()}</td>
                <td class="py-2">${typeBadge}<br><span class="text-[10px] text-gray-400">${t.reference || ''}</span></td>
                <td class="py-2 text-right font-medium">${amountText}</td>
            </tr>
        `;
    });
};

const loadCustomerPurchases = async (customerId) => {
    const tbody = document.getElementById('cust-purchases-body');
    tbody.innerHTML = '';
    
    const sales = await db.sales_header.where('customerId').equals(customerId).toArray();
    sales.sort((a,b) => new Date(b.date) - new Date(a.date));
    
    if(sales.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-gray-500">No purchase history.</td></tr>';
        return;
    }
    
    sales.forEach(sale => {
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-gray-600">${new Date(sale.date).toLocaleString()}</td>
                <td class="p-3 font-medium text-gray-800">${sale.invoiceNo}</td>
                <td class="p-3 text-right text-gray-600">${sale.itemCount || 0}</td>
                <td class="p-3 text-right font-bold text-gray-800">Rs. ${formatCurrency(sale.netTotal)}</td>
                <td class="p-3 text-center">
                    <button class="text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-2 py-1 rounded text-xs font-medium transition-colors" onclick="alert('Print functionality not implemented in this demo')">View</button>
                </td>
            </tr>
        `;
    });
};

