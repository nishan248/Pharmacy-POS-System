const openCustomerProfile = async (id, name) => {
    document.getElementById('presc-cust-id').value = id;
    document.getElementById('prof-cust-name').innerText = name;
    document.getElementById('form-add-prescription').reset();
    await loadPrescriptions(id);
    openModal('modal-customer-profile');
};

const savePrescription = async () => {
    const customerId = parseInt(document.getElementById('presc-cust-id').value);
    const doctorName = document.getElementById('presc-doctor').value.trim();
    const date = document.getElementById('presc-date').value;
    const notes = document.getElementById('presc-notes').value.trim();
    
    const fileInput = document.getElementById('presc-image');
    let imageString = '';

    if(fileInput.files.length > 0) {
        const file = fileInput.files[0];
        const reader = new FileReader();
        reader.onloadend = async () => {
            imageString = reader.result;
            await insertPrescription(customerId, doctorName, date, notes, imageString);
        };
        reader.readAsDataURL(file);
    } else {
        await insertPrescription(customerId, doctorName, date, notes, imageString);
    }
};

const insertPrescription = async (customerId, doctorName, date, notes, imageString) => {
    try {
        await db.prescriptions.add({ customerId, doctorName, date, notes, imageString });
        showToast('Prescription saved', 'success');
        document.getElementById('form-add-prescription').reset();
        loadPrescriptions(customerId);
        if(document.getElementById('pos-customer-select').value == customerId) {
            posCustomerChanged(); // Reload dropdown in POS
        }
    } catch(e) {
        showToast('Error saving prescription', 'error');
    }
};

const loadPrescriptions = async (customerId) => {
    const container = document.getElementById('prescriptions-list');
