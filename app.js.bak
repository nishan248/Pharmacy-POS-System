            <p class="text-sm text-gray-500 font-medium">Total GRNs</p>
            <h2 class="text-3xl font-bold text-blue-600 mt-1">${filteredGRNs.length}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Completed Purchases (GRN)';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">GRN No</th>
            <th class="p-3 font-medium border-b border-gray-200">Date</th>
            <th class="p-3 font-medium border-b border-gray-200">Supplier</th>
            <th class="p-3 font-medium border-b border-gray-200">Invoice No</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Total Amount</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(filteredGRNs.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-gray-500">No completed purchases found for this period.</td></tr>';
        return;
    }

    filteredGRNs.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(g => {
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-blue-600 font-medium">${g.grnNo}</td>
                <td class="p-3 text-sm text-gray-600">${g.date}</td>
                <td class="p-3 text-sm text-gray-800">${g.supplierName || '-'}</td>
                <td class="p-3 text-sm text-gray-600">${g.invoiceNo || '-'}</td>
                <td class="p-3 text-right font-bold text-gray-800">${formatCurrency(g.netAmount)}</td>
            </tr>
        `;
    });
};

const generatePrescriptionsReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allSales = await db.sales.toArray();
    
    const filteredSales = allSales.filter(s => {
