                <td class="p-3 text-sm text-gray-800">#${s.prescriptionId}</td>
                <td class="p-3 text-right font-bold text-gray-800">${formatCurrency(s.netAmount)}</td>
            </tr>
        `;
    });
};

const generateControlledReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allDrugs = await db.drugs.toArray();
    const controlledDrugs = allDrugs.filter(d => d.isControlled);
    const controlledDrugIds = controlledDrugs.map(d => d.id);
    
    const allLedger = await db.stock_ledger.toArray();
    const filteredLedger = allLedger.filter(l => {
        const lDate = new Date(l.date);
        return lDate >= startDate && lDate <= endDate && controlledDrugIds.includes(l.drugId);
    });

    // Update Summary
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Controlled Items Tracked</p>
            <h2 class="text-3xl font-bold text-purple-600 mt-1">${controlledDrugs.length}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm md:col-span-2">
            <p class="text-sm text-gray-500 font-medium">Transactions in Period</p>
            <h2 class="text-3xl font-bold text-blue-600 mt-1">${filteredLedger.length}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Controlled Drugs Register';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Date/Time</th>
            <th class="p-3 font-medium border-b border-gray-200">Drug Name</th>
            <th class="p-3 font-medium border-b border-gray-200">Type</th>
            <th class="p-3 font-medium border-b border-gray-200">Reference</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Qty Change</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(filteredLedger.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-gray-500">No controlled drug transactions in this period.</td></tr>';
        return;
    }

    filteredLedger.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(l => {
        const drug = controlledDrugs.find(d => d.id === l.drugId);
        const qtyColor = l.qty > 0 ? 'text-green-600' : 'text-red-600';
        const qtySign = l.qty > 0 ? '+' : '';
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-sm text-gray-600">${formatDate(l.date)}</td>
                <td class="p-3 text-gray-800 font-bold">${drug?.brandName || 'Unknown'}</td>
                <td class="p-3"><span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-xs font-medium uppercase">${l.transactionType}</span></td>
                <td class="p-3 text-sm text-gray-600">${l.reference || '-'}</td>
                <td class="p-3 text-right font-bold ${qtyColor}">${qtySign}${l.qty}</td>
            </tr>
        `;
    });
};

const generateAdjustmentsReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allLedger = await db.stock_ledger.toArray();
    const filteredLedger = allLedger.filter(l => {
        const lDate = new Date(l.date);
        return lDate >= startDate && lDate <= endDate && l.transactionType === 'ADJUSTMENT';
    });

    const totalPositive = filteredLedger.filter(l => l.qty > 0).reduce((sum, l) => sum + l.qty, 0);
    const totalNegative = filteredLedger.filter(l => l.qty < 0).reduce((sum, l) => sum + Math.abs(l.qty), 0);

    // Update Summary
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Total Adjustments</p>
            <h2 class="text-3xl font-bold text-gray-800 mt-1">${filteredLedger.length}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Positive Qty Changes</p>
            <h2 class="text-3xl font-bold text-green-600 mt-1">+${totalPositive}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Negative Qty Changes</p>
            <h2 class="text-3xl font-bold text-red-600 mt-1">-${totalNegative}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Stock Adjustments Report';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Date/Time</th>
            <th class="p-3 font-medium border-b border-gray-200">Drug Name</th>
            <th class="p-3 font-medium border-b border-gray-200">Reason / Ref</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Qty Change</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(filteredLedger.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-gray-500">No stock adjustments in this period.</td></tr>';
        return;
    }

    for (let l of filteredLedger.sort((a,b) => new Date(b.date) - new Date(a.date))) {
        const drug = await db.drugs.get(l.drugId);
        const qtyColor = l.qty > 0 ? 'text-green-600' : 'text-red-600';
        const qtySign = l.qty > 0 ? '+' : '';
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-sm text-gray-600">${formatDate(l.date)}</td>
                <td class="p-3 text-gray-800 font-bold">${drug?.brandName || 'Unknown'}</td>
                <td class="p-3 text-sm text-gray-600">${l.reference || '-'}</td>
                <td class="p-3 text-right font-bold ${qtyColor}">${qtySign}${l.qty}</td>
            </tr>
        `;
    }
};

const generateBusinessReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allSales = await db.sales.toArray();
    const filteredSales = allSales.filter(s => {
        const sDate = new Date(s.dateTime);
        return sDate >= startDate && sDate <= endDate;
    });

    const totalRevenue = filteredSales.reduce((sum, s) => sum + s.netAmount, 0);
    const totalProfit = filteredSales.reduce((sum, s) => sum + (s.profit || 0), 0);
    const totalCOGS = totalRevenue - totalProfit;
    const margin = totalRevenue > 0 ? ((totalProfit / totalRevenue) * 100).toFixed(1) : 0;

    // Update Summary
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Total Sales Revenue</p>
            <h2 class="text-3xl font-bold text-gray-800 mt-1">${formatCurrency(totalRevenue)}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Cost of Goods Sold (COGS)</p>
            <h2 class="text-3xl font-bold text-red-600 mt-1">${formatCurrency(totalCOGS)}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Gross Profit</p>
            <h2 class="text-3xl font-bold text-green-600 mt-1">${formatCurrency(totalProfit)}</h2>
            <p class="text-xs text-gray-500 mt-1">Margin: ${margin}%</p>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Monthly Business Performance';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Date Range</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Total Revenue</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">COGS</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Gross Profit</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Margin</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = `
        <tr class="hover:bg-gray-50">
            <td class="p-3 text-sm text-gray-800 font-medium">${startDate.toLocaleDateString()} - ${endDate.toLocaleDateString()}</td>
            <td class="p-3 text-right text-gray-800 font-bold">${formatCurrency(totalRevenue)}</td>
            <td class="p-3 text-right text-red-600 font-medium">${formatCurrency(totalCOGS)}</td>
            <td class="p-3 text-right text-green-600 font-bold">${formatCurrency(totalProfit)}</td>
            <td class="p-3 text-right text-gray-600">${margin}%</td>
        </tr>
    `;
};




window.printCurrentReport = () => {
    const reportTypeSelect = document.getElementById('report-type');
    const reportTitle = reportTypeSelect.options[reportTypeSelect.selectedIndex].text;
    
    let dateInfo = '';
    if (reportTypeSelect.value !== 'inventory' && reportTypeSelect.value !== 'low_stock') {
        const { startDate, endDate } = getReportDateRange();
        dateInfo = `<p style="margin:2px 0;">Date Range: ${startDate.toLocaleDateString()} to ${endDate.toLocaleDateString()}</p>`;
    }

    const summaryHTML = document.getElementById('report-summary-container').innerHTML;
    const tableHeadHTML = document.getElementById('report-table-head').innerHTML;
    const tableBodyHTML = document.getElementById('report-table-body').innerHTML;

    let printHTML = `
        <div style="font-family: Arial, sans-serif; padding: 20px;">
            <div style="text-align:center; border-bottom: 2px solid #333; padding-bottom: 15px; margin-bottom: 20px;">
                <h1 style="margin: 0; font-size: 24px;">NEXUS PHARMACY</h1>
                <h2 style="margin: 5px 0; font-size: 18px; color: #555;">${reportTitle}</h2>
                ${dateInfo}
                <p style="margin: 2px 0; font-size: 12px; color: #777;">Printed on: ${new Date().toLocaleString()}</p>
            </div>
            
            <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                ${summaryHTML.replace(/class="[^"]*"/g, 'style="border: 1px solid #ccc; padding: 15px; flex: 1; border-radius: 5px;"')}
            </div>

            <table style="width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 14px;">
                <thead style="background-color: #f5f5f5;">
                    ${tableHeadHTML.replace(/<th([^>]*)>/g, '<th$1 style="padding: 10px; border: 1px solid #ddd; text-align: left;">')}
                </thead>
                <tbody>
                    ${tableBodyHTML.replace(/<td([^>]*)>/g, '<td$1 style="padding: 8px; border: 1px solid #ddd;">')}
                </tbody>
            </table>
            
            <div style="margin-top: 30px; border-top: 1px solid #ddd; padding-top: 10px; text-align: center; font-size: 12px; color: #777;">
                Generated by Nexus POS System
            </div>
        </div>
    `;

    const printContainer = document.getElementById('print-report-container');
    printContainer.innerHTML = printHTML;
    
    document.getElementById('print-receipt-container').innerHTML = ''; // Ensure receipt container is empty
    
    window.print();
};

window.viewInvoice = async (saleId) => {
    try {
        const sale = await db.sales.get(parseInt(saleId));
        if(!sale) return;
        
        const saleItems = await db.salesItems.where('saleId').equals(sale.id).toArray();
        let itemsWithNames = [];
        for(let item of saleItems) {
            const drug = await db.drugs.get(item.drugId);
            const batch = await db.batches.get(item.batchId);
            itemsWithNames.push({
                brandName: drug ? drug.brandName : 'Unknown Item',
                batchNumber: batch ? batch.batchNumber : 'N/A',
                qty: item.qty,
                unitPrice: item.unitPrice
            });
        }
        
        let receiptHTML = `
            <div style="background:white; padding:15px; border-radius:5px; border:1px solid #eee; margin:0 auto; font-family: monospace; font-size:12px; color:black; max-width:300px;">
                <div style="text-align:center; border-bottom:1px dashed #000; padding-bottom:10px; margin-bottom:10px;">
                    <h2 style="margin:0; font-size:18px;">NEXUS PHARMACY</h2>
                    <p style="margin:0;">123 Main Street, City</p>
                    <p style="margin:0;">Tel: 011-2345678</p>
                </div>
                <div style="margin-bottom:10px;">
                    <p style="margin:2px 0;">Invoice: ${sale.invoiceNumber}</p>
                    <p style="margin:2px 0;">Date: ${formatDate(sale.dateTime)}</p>
                    ${sale.customer ? `<p style="margin:2px 0;">Customer: ${sale.customer}</p>` : ''}
                </div>
                <table style="width:100%; border-collapse: collapse; margin-bottom:10px;">
                    <tr style="border-bottom:1px dashed #000;">
                        <th style="text-align:left; padding:2px 0;">Item</th>
                        <th style="text-align:right; padding:2px 0;">Qty</th>
                        <th style="text-align:right; padding:2px 0;">Total</th>
                    </tr>
        `;

        itemsWithNames.forEach(i => {
            receiptHTML += `
                <tr>
                    <td style="padding:2px 0;">${i.brandName} <span style="font-size:10px;">(${i.batchNumber})</span></td>
                    <td style="text-align:right; padding:2px 0;">${i.qty}</td>
                    <td style="text-align:right; padding:2px 0;">${(i.qty * i.unitPrice).toFixed(2)}</td>
                </tr>
            `;
        });

        receiptHTML += `
                </table>
                <div style="text-align:right; border-top:1px dashed #000; padding-top:5px; margin-bottom:10px;">
                    <p style="margin:2px 0;">Subtotal: ${sale.totalAmount.toFixed(2)}</p>
                    <p style="margin:2px 0;">Discount: ${sale.discount.toFixed(2)}</p>
                    <h3 style="margin:5px 0; font-size:16px;">Total: Rs. ${sale.netAmount.toFixed(2)}</h3>
                    ${sale.paymentMethod === 'split' && sale.splitPayments 
                        ? sale.splitPayments.map(p => `<p style="margin:2px 0;">${p.method.toUpperCase()}: ${p.amount.toFixed(2)}</p>`).join('')
                        : `<p style="margin:2px 0;">Method: ${(sale.paymentMethod || '').toUpperCase()}</p>`}
                </div>
                <div style="text-align:center; border-top:1px dashed #000; padding-top:10px;">
                    <p style="margin:0;">Thank you for your business!</p>
                    <p style="margin:0;">Get well soon.</p>
                </div>
            </div>
        `;

        document.getElementById('invoice-viewer-content').innerHTML = receiptHTML;
        document.getElementById('print-receipt-container').innerHTML = receiptHTML;
        openModal('modal-invoice-viewer');
    } catch(e) {
        console.error(e);
        showToast('Error loading invoice', 'error');
    }
};

window.printCurrentInvoice = () => {
    window.print();
};


// ==========================================
// 9. BACKUP & RESTORE
// ==========================================
const exportDatabase = async () => {
    try {
        const data = {
            drugs: await db.drugs.toArray(),
            batches: await db.batches.toArray(),
            sales: await db.sales.toArray(),
            salesItems: await db.salesItems.toArray()
        };
        
        const json = JSON.stringify(data);
        const blob = new Blob([json], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = `NexusPOS_Backup_${new Date().toISOString().split('T')[0]}.json`;
        a.click();
        
        URL.revokeObjectURL(url);
        showToast('Backup downloaded successfully', 'success');
    } catch(e) {
        showToast('Error exporting data: ' + e.message, 'error');
    }
};

const importDatabase = () => {
    const fileInput = document.getElementById('import-file');
    const file = fileInput.files[0];
    
    if(!file) return showToast('Please select a JSON backup file first', 'error');

    if(!confirm('Warning: This will overwrite your current database with the backup data. Continue?')) return;

    const reader = new FileReader();
    reader.onload = async (e) => {
        try {
            const data = JSON.parse(e.target.result);
            
            // Validate basic structure
            if(!data.drugs || !data.batches || !data.sales) {
                throw new Error("Invalid backup file structure.");
            }

            await db.transaction('rw', db.drugs, db.batches, db.sales, db.salesItems, async () => {
                await db.drugs.clear();
                await db.batches.clear();
                await db.sales.clear();
                await db.salesItems.clear();

                await db.drugs.bulkAdd(data.drugs);
                await db.batches.bulkAdd(data.batches);
                await db.sales.bulkAdd(data.sales);
                if(data.salesItems) await db.salesItems.bulkAdd(data.salesItems);
            });
            
            showToast('Database restored successfully! Reloading...', 'success');
            setTimeout(() => window.location.reload(), 1500);
            
        } catch(err) {
            console.error(err);
            showToast('Failed to restore database: ' + err.message, 'error');
        }
    };
    reader.readAsText(file);
};

const clearDatabase = async () => {
    if(prompt('Type "DELETE" to confirm erasing all data:') === 'DELETE') {
        try {
            await db.delete();
            showToast('Database erased. Reloading...', 'success');
            setTimeout(() => window.location.reload(), 1500);
        } catch(e) {
            showToast('Error erasing database', 'error');
        }
    }
};

