const customerSearchInput = document.getElementById('pos-customer-search');
const customerSearchResults = document.getElementById('pos-customer-results');

customerSearchInput.addEventListener('input', async (e) => {
    const query = e.target.value.toLowerCase().trim();
    if(query.length < 2) {
        customerSearchResults.classList.add('hidden');
        return;
    }

    try {
        const customers = await db.customers.toArray();
        const matches = customers.filter(c => 
            c.name.toLowerCase().includes(query) || 
            c.phone.includes(query)
        );

        customerSearchResults.innerHTML = '';
        if(matches.length === 0) {
            customerSearchResults.innerHTML = '<div class="p-2 text-gray-500 text-xs text-center">No customers found</div>';
        } else {
            matches.forEach(c => {
                const div = document.createElement('div');
                div.className = 'p-2 border-b border-gray-100 hover:bg-blue-50 cursor-pointer text-sm';
                div.innerHTML = `<span class="font-medium text-gray-800">${c.name}</span> <br><span class="text-xs text-gray-500">${c.phone}</span>`;
                div.onclick = () => selectPOSCustomer(c);
                customerSearchResults.appendChild(div);
            });
        }
        customerSearchResults.classList.remove('hidden');
    } catch(e) {}
});

document.addEventListener('click', (e) => {
    if(!customerSearchInput.contains(e.target) && !customerSearchResults.contains(e.target)) {
        customerSearchResults.classList.add('hidden');
    }
});

const selectPOSCustomer = async (customer) => {
    document.getElementById('pos-customer-id').value = customer.id;
    document.getElementById('pos-cust-name-disp').innerText = customer.name;
    document.getElementById('pos-cust-phone-disp').innerText = customer.phone;
    document.getElementById('pos-cust-points-disp').innerText = customer.loyaltyPoints || 0;
    
    customerSearchInput.value = '';
    customerSearchInput.classList.add('hidden');
    customerSearchResults.classList.add('hidden');
    document.getElementById('pos-selected-customer').classList.remove('hidden');
    
    // Load prescriptions
    const prescSelect = document.getElementById('pos-prescription-select');
    const prescriptions = await db.prescriptions.where('customerId').equals(customer.id).toArray();
    
    if(prescriptions.length > 0) {
        prescSelect.classList.remove('hidden');
        let html = '<option value="">-- Attach a Prescription --</option>';
        prescriptions.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(p => {
            html += `<option value="${p.id}">Dr. ${p.doctorName} (${p.date})</option>`;
        });
        prescSelect.innerHTML = html;
    } else {
        prescSelect.classList.add('hidden');
        prescSelect.innerHTML = '<option value="">No Prescription</option>';
    }
};

const clearPOSCustomer = () => {
    document.getElementById('pos-customer-id').value = '';
    document.getElementById('pos-selected-customer').classList.add('hidden');
    customerSearchInput.classList.remove('hidden');
    customerSearchInput.value = '';
    
    const prescSelect = document.getElementById('pos-prescription-select');
    prescSelect.classList.add('hidden');
    prescSelect.innerHTML = '<option value="">No Prescription</option>';
};

// Replace old loadPOSCustomers logic (deleted the dropdown)
const loadPOSCustomers = async () => {}; 
const posCustomerChanged = async () => {};

// Checkout logic tied to the Payment Modal
window.processCheckout = async () => {
    if(currentCart.length === 0) return showToast('Cart is empty', 'error');

    const totals = updateTotals();
    const invoiceNumber = window.currentInvoiceNo || 'INV-' + Date.now().toString().slice(-6);
    
    const checkoutCalc = updateCheckoutBalance();
    const finalAmountToPay = checkoutCalc.remainingTotal;
    
    if (window.checkoutPayments.length === 0) {
        return showToast('Please add at least one payment method.', 'error');
    }
    
    if (checkoutCalc.remainingToPay > 0) {
        return showToast('Full amount has not been paid.', 'error');
    }

    // Check if change is only cash. Non-cash payments shouldn't exceed bill.
    const nonCashTotal = window.checkoutPayments.filter(p => p.method !== 'cash').reduce((sum, p) => sum + p.amount, 0);
    if (nonCashTotal > finalAmountToPay) {
        return showToast('Non-cash payments cannot exceed the total bill amount.', 'error');
    }
    
    // Handle PIN Prompt if redeeming points or credit
    if(checkoutCalc.pointsDiscount > 0 || checkoutCalc.creditDiscount > 0) {
        if(!window.checkoutCustomer.pin) {
            return showToast('Customer must set a PIN in their profile to redeem points/credit.', 'error');
        }
        const enteredPin = prompt('Enter 4-digit Customer PIN to authorize redemption:');
        if(enteredPin !== window.checkoutCustomer.pin) {
            return showToast('Invalid PIN. Checkout aborted.', 'error');
        }
    }
    
    // Updated POS fields
    const customerIdStr = document.getElementById('pos-customer-id').value;
    const customerId = customerIdStr ? parseInt(customerIdStr) : null;
    const customerText = customerId ? document.getElementById('pos-cust-name-disp').innerText : 'Walk-in Customer';
    
    const prescSelect = document.getElementById('pos-prescription-select');
    const prescriptionId = prescSelect.value ? parseInt(prescSelect.value) : null;
    const doctorNotes = document.getElementById('pos-doctor').value;
    const profit = totals.total - totals.totalCost; // Original profit calculation

    // Determine primary payment method to store for backwards compatibility
    let primaryMethod = window.checkoutPayments[0].method;
    if (window.checkoutPayments.length > 1) {
        primaryMethod = 'split';
    }

    const splitPaymentsToStore = window.checkoutPayments.map(p => ({ method: p.method, amount: p.amount }));
    if (checkoutCalc.changeDue > 0) {
        const cashPayment = splitPaymentsToStore.find(p => p.method === 'cash');
        if (cashPayment) {
            cashPayment.amount -= checkoutCalc.changeDue;
        }
    }

    const saleRecord = {
        invoiceNumber,
        dateTime: new Date().toISOString(),
        totalAmount: totals.subtotal,
        discount: totals.discountAmount, // Standard discount
        pointsDiscount: checkoutCalc.pointsDiscount,
        creditDiscount: checkoutCalc.creditDiscount,
        netAmount: finalAmountToPay, // Final amount after all deductions
        paymentMethod: primaryMethod,
        splitPayments: splitPaymentsToStore,
        profit: profit,
        customerId: customerId,
        prescriptionId: prescriptionId,
        customer: customerText,
        doctor: doctorNotes,
        itemCount: currentCart.reduce((sum, i) => sum + i.qty, 0)
    };

    try {
        await db.transaction('rw', db.sales, db.salesItems, db.batches, db.stock_ledger, db.customers, db.wallet_transactions, async () => {
            const saleId = await db.sales.add(saleRecord);
            for(const item of currentCart) {
                await db.salesItems.add({
                    saleId: saleId,
                    drugId: item.drugId,
                    batchId: item.batchId,
                    qty: item.qty,
                    unitPrice: item.unitPrice,
                    total: item.qty * item.unitPrice
                });
                const batch = await db.batches.get(item.batchId);
                await db.batches.update(item.batchId, { qty: batch.qty - item.qty });
                
                await db.stock_ledger.add({
                    date: saleRecord.dateTime,
                    drugId: item.drugId,
                    batchId: item.batchId,
                    transactionType: 'SALE',
                    qtyChange: -item.qty,
                    reference: invoiceNumber
                });
            }
            
            // Wallet operations
            if(window.checkoutCustomer) {
                let updatedLoyalty = window.checkoutCustomer.loyaltyPoints || 0;
                let updatedCredit = window.checkoutCustomer.storeCredit || 0;
                
                // Deduct used points/credit
                if(checkoutCalc.pointsDiscount > 0) {
                    updatedLoyalty -= checkoutCalc.pointsDiscount;
                    await db.wallet_transactions.add({
                        customerId, amount: checkoutCalc.pointsDiscount, type: 'redeem_points', date: saleRecord.dateTime, reference: invoiceNumber
                    });
                }
                
                if(checkoutCalc.creditDiscount > 0) {
                    updatedCredit -= checkoutCalc.creditDiscount;
                    await db.wallet_transactions.add({
                        customerId, amount: checkoutCalc.creditDiscount, type: 'use_credit', date: saleRecord.dateTime, reference: invoiceNumber
                    });
                }
                
                // Add points for purchase (1 point per Rs. 100 paid in finalAmountToPay)
                if(finalAmountToPay >= 100) {
                    const earnedPoints = Math.floor(finalAmountToPay / 100);
                    updatedLoyalty += earnedPoints;
                    await db.wallet_transactions.add({
                        customerId, amount: earnedPoints, type: 'earn_points', date: saleRecord.dateTime, reference: invoiceNumber
                    });
                }
                
                // Convert change to points if amount is entered
                const addedPointsVal = parseFloat(document.getElementById('checkout-add-points-amount').value) || 0;
                if(addedPointsVal > 0 && checkoutCalc.balance >= addedPointsVal) {
                    updatedLoyalty += addedPointsVal;
                    await db.wallet_transactions.add({
                        customerId, amount: addedPointsVal, type: 'earn_points', date: saleRecord.dateTime, reference: invoiceNumber + ' Change Converted'
                    });
                } else if (addedPointsVal > checkoutCalc.balance) {
                    throw new Error('Cannot convert more change to points than the available balance.');
                }
                
                // Update customer record
                await db.customers.update(customerId, {
                    loyaltyPoints: updatedLoyalty,
                    storeCredit: updatedCredit
                });
            }
        });
        
        printReceipt(saleRecord, currentCart);
        showToast(`Sale Successful. Invoice: ${invoiceNumber}`, 'success');
        closeModal('modal-checkout');
        clearCart(); // Clear cart also generates new invoice number
        
        // Refresh customer UI if it's open
        if(window.currentCustomerId) loadCustomers();
        
    } catch(e) {
        showToast('Error processing sale: ' + e.message, 'error');
    }
};

