// ==========================================
// 1. DATABASE SETUP (Dexie.js)
// ==========================================
const db = new Dexie('PharmacyPOSDB');
db.version(1).stores({
    drugs: '++id, brandName, genericName, rackLocation',
    batches: '++id, drugId, batchNumber, expiryDate, qty, costPrice, sellingPrice',
    sales: '++id, invoiceNumber, dateTime, totalAmount, discount, netAmount, paymentMethod, profit',
    salesItems: '++id, saleId, drugId, batchId, qty, unitPrice, total',
    suppliers: '++id, name, phone'
});
db.version(2).stores({
    sales: '++id, invoiceNumber, dateTime, totalAmount, discount, netAmount, paymentMethod, profit, customerId, prescriptionId',
    suppliers: '++id, name, phone, email, address, pendingDues',
    customers: '++id, name, phone, email, address, medicalNotes',
    prescriptions: '++id, customerId, doctorName, date, notes, imageString'
});
db.version(3).stores({
    grn_header: '++id, grnNo, date, supplierId, status',
    grn_items: '++id, grnId, drugId, batchNumber, expiryDate',
    stock_ledger: '++id, date, drugId, batchId, transactionType',
    accounts_payable: '++id, supplierId, grnId, date, status',
    drugs: '++id, brandName, genericName, rackLocation, isControlled, isColdChain'
});
db.version(4).stores({
    users: '++id, username, password, role, fullName'
});
db.version(5).stores({
    // clinical logs removed
});
db.version(6).stores({
    drugs: '++id, brandName, genericName, rackLocation, isControlled, isColdChain, mbq'
});
db.version(7).stores({
    disposals: '++id, date, type, drugId, batchId, qty, unitCost, totalLoss, notes'
});
db.version(8).stores({
    suppliers: '++id, name, contactPerson, phone, email, address, paymentTerms, pendingDues',
    supplier_payments: '++id, date, supplierId, amount, paymentMethod, reference, notes'
});
db.version(9).stores({
    batches: '++id, drugId, supplierId, batchNumber, expiryDate, qty, costPrice, sellingPrice',
    disposals: '++id, date, type, drugId, batchId, supplierId, qty, unitCost, totalLoss, notes'
});
db.version(10).stores({
    customers: '++id, name, phone, address, pin, loyaltyPoints, storeCredit',
    wallet_transactions: '++id, date, customerId, type, amount, reference, notes'
});
db.version(11).stores({
    purchase_orders: '++id, poNumber, date, supplierId, status',
    po_items: '++id, poId, drugId, qty, unitCost, total'
});
db.version(12).stores({
    day_end_records: '++id, date, expectedCash, actualCash, variance, cardSales, creditSales, totalSales, notes, performedBy'
});


// ==========================================
// 2. STATE & UTILS
// ==========================================
let currentCart = [];
let currentPaymentMethod = 'cash';
let salesChartInstance = null;

// Currency formatter
const formatCurrency = (amount) => {
    return new Intl.NumberFormat('en-LK', { style: 'currency', currency: 'LKR' }).format(amount);
};

// Date formatter
const formatDate = (dateString) => {
    const d = new Date(dateString);
    return d.toLocaleDateString('en-GB') + ' ' + d.toLocaleTimeString('en-US', {hour: '2-digit', minute:'2-digit'});
};

// Toast Notifications
const showToast = (message, type = 'info') => {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    
    let icon = 'fa-circle-info';
    if(type === 'success') icon = 'fa-circle-check';
    if(type === 'error') icon = 'fa-circle-xmark';
    if(type === 'warning') icon = 'fa-triangle-exclamation';
    
    toast.innerHTML = `<i class="fa-solid ${icon} mr-2"></i> ${message}`;
    container.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOut 0.3s ease forwards';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
};

// ==========================================
// 3. NAVIGATION LOGIC (SPA)
// ==========================================
const nav = (target) => {
    // Check role access
    const currentUserStr = sessionStorage.getItem('currentUser');
    if (currentUserStr) {
        const user = JSON.parse(currentUserStr);
        const roleAccess = {
            'Admin': ['dashboard', 'pos', 'inventory', 'grn', 'reports', 'dayend', 'customers', 'suppliers', 'expiry', 'users', 'settings'],
            'Cashier': ['dashboard', 'pos', 'dayend', 'customers', 'settings'],
            'Pharmacist': ['dashboard', 'inventory', 'grn', 'reports', 'dayend', 'suppliers', 'expiry', 'settings']
        };
        const allowedTargets = roleAccess[user.role] || [];
        if (!allowedTargets.includes(target)) {
            showToast('Access Denied', 'error');
            return;
        }
    }

    // Update active nav button
    document.querySelectorAll('.nav-item').forEach(btn => btn.classList.remove('active'));
    document.querySelector(`[data-target="${target}"]`).classList.add('active');
    
    // Hide all sections, show target
    document.querySelectorAll('.app-section').forEach(sec => {
        sec.classList.remove('active');
        sec.classList.add('hidden');
    });
    
    const targetEl = document.getElementById(target);
    targetEl.classList.remove('hidden');
    // Force a small reflow to trigger animation
    void targetEl.offsetWidth; 
    targetEl.classList.add('active');
    
    // Update title
    document.getElementById('page-title').innerText = target.charAt(0).toUpperCase() + target.slice(1).replace('-', ' ');

    // Call section specific initialization
    if(target === 'dashboard') loadDashboard();
    if(target === 'inventory') loadInventory();
    if(target === 'grn') loadGRNDashboard();
    if(target === 'customers') loadCustomers();
    if(target === 'suppliers') loadSuppliers();
    if(target === 'pos') {
        document.getElementById('pos-search').focus();
        if(!window.currentInvoiceNo) generateInvoiceNumber();
    }
    if(target === 'reports') generateReport();
};

// ==========================================
// 4. MODAL LOGIC
// ==========================================
const openModal = (id) => {
    const modal = document.getElementById(id);
    modal.classList.remove('hidden');
    setTimeout(() => {
        modal.querySelector('.modal-content').classList.remove('scale-95', 'opacity-0');
        modal.querySelector('.modal-content').classList.add('scale-100', 'opacity-100');
    }, 10);
};

const closeModal = (id) => {
    const modal = document.getElementById(id);
    modal.querySelector('.modal-content').classList.remove('scale-100', 'opacity-100');
    modal.querySelector('.modal-content').classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
        modal.classList.add('hidden');
    }, 200);
};

// ==========================================
// 5. INVENTORY MANAGEMENT
// ==========================================
const saveDrug = async () => {
    const idStr = document.getElementById('drug-id').value;
    const brandName = document.getElementById('drug-brand').value.trim();
    const genericName = document.getElementById('drug-generic').value.trim();
    const type = document.getElementById('drug-type').value;
    const dosage = document.getElementById('drug-dosage').value.trim();
    const rackLocation = document.getElementById('drug-location').value.trim();
    const mbq = parseInt(document.getElementById('drug-mbq').value) || 0;
    const isControlled = document.getElementById('drug-controlled') ? document.getElementById('drug-controlled').checked : false;
    const isColdChain = document.getElementById('drug-coldchain') ? document.getElementById('drug-coldchain').checked : false;

    if(!brandName) return showToast('Brand Name is required', 'error');

    try {
        const drugData = { brandName, genericName, type, dosage, rackLocation, isControlled, isColdChain, mbq };
        if(idStr) {
            await db.drugs.update(parseInt(idStr), drugData);
            showToast('Drug updated successfully', 'success');
        } else {
            await db.drugs.add(drugData);
            showToast('Drug added successfully', 'success');
        }
        closeModal('modal-add-drug');
        document.getElementById('form-add-drug').reset();
        document.getElementById('drug-id').value = '';
        loadInventory();
    } catch (e) {
        showToast('Error saving drug: ' + e.message, 'error');
    }
};

window.openAddDrugModal = () => {
    document.getElementById('form-add-drug').reset();
    document.getElementById('drug-id').value = '';
    document.getElementById('modal-drug-title').innerText = 'Add New Drug Profile';
    openModal('modal-add-drug');
};

window.editDrug = async (id) => {
    try {
        const drug = await db.drugs.get(id);
        if(!drug) return showToast('Drug not found', 'error');
        
        document.getElementById('drug-id').value = drug.id;
        document.getElementById('drug-brand').value = drug.brandName;
        document.getElementById('drug-generic').value = drug.genericName || '';
        document.getElementById('drug-type').value = drug.type || 'Tablet';
        document.getElementById('drug-dosage').value = drug.dosage || '';
        document.getElementById('drug-location').value = drug.rackLocation || '';
        document.getElementById('drug-mbq').value = drug.mbq !== undefined ? drug.mbq : 20;
        
        if(document.getElementById('drug-controlled')) document.getElementById('drug-controlled').checked = drug.isControlled;
        if(document.getElementById('drug-coldchain')) document.getElementById('drug-coldchain').checked = drug.isColdChain;
        
        document.getElementById('modal-drug-title').innerText = 'Edit Drug Profile';
        openModal('modal-add-drug');
    } catch(e) {
        console.error(e);
        showToast('Error loading drug', 'error');
    }
};

const loadInventory = async () => {
    const search = document.getElementById('inv-search')?.value.toLowerCase() || '';
    const tbody = document.getElementById('inventory-table-body');
    tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4">Loading...</td></tr>';

    try {
        let drugs = await db.drugs.toArray();
        if(search) {
            drugs = drugs.filter(d => 
                d.brandName.toLowerCase().includes(search) || 
                d.genericName.toLowerCase().includes(search)
            );
        }

        tbody.innerHTML = '';
        if(drugs.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-gray-500">No drugs found in inventory.</td></tr>';
            return;
        }

        for (const drug of drugs) {
            // Get total qty from batches
            const batches = await db.batches.where('drugId').equals(drug.id).toArray();
            const totalQty = batches.reduce((sum, b) => sum + b.qty, 0);
            
            const mbqThreshold = drug.mbq !== undefined ? drug.mbq : 20;

            let qtyClass = 'text-green-600';
            if(totalQty === 0) qtyClass = 'text-red-600 font-bold';
            else if(totalQty <= mbqThreshold) qtyClass = 'text-orange-500 font-bold';

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="p-4 font-medium text-gray-900">${drug.brandName} ${drug.dosage ? `<span class="text-xs text-gray-500">(${drug.dosage})</span>` : ''}</td>
                <td class="p-4 text-gray-600">${drug.genericName || '-'} <br><span class="text-xs bg-gray-100 px-2 py-0.5 rounded">${drug.type}</span></td>
                <td class="p-4 text-gray-600">${drug.rackLocation || '-'}</td>
                <td class="p-4 text-right ${qtyClass}">${totalQty}</td>
                <td class="p-4 text-center flex justify-center gap-2">
                    <button onclick="editDrug(${drug.id})" class="text-green-600 hover:text-green-800 hover:bg-green-50 px-3 py-1.5 rounded transition-colors text-sm font-medium border border-green-200" title="Edit Drug">
                        <i class="fa-solid fa-pen mr-1"></i> Edit
                    </button>
                    <button onclick="openDrugProfile(${drug.id})" class="text-indigo-600 hover:text-indigo-800 hover:bg-indigo-50 px-3 py-1.5 rounded transition-colors text-sm font-medium border border-indigo-200" title="View Profile & Ledger">
                        <i class="fa-solid fa-address-card mr-1"></i> Profile
                    </button>
                    <button onclick="openManageBatches(${drug.id}, '${drug.brandName.replace(/'/g, "\\'")}')" class="text-blue-600 hover:text-blue-800 hover:bg-blue-50 px-3 py-1.5 rounded transition-colors text-sm font-medium border border-blue-200">
                        <i class="fa-solid fa-layer-group mr-1"></i> Batches
                    </button>
                </td>
            `;
            tbody.appendChild(tr);
        }
    } catch(e) {
        console.error(e);
        tbody.innerHTML = '<tr><td colspan="5" class="text-center p-4 text-red-500">Error loading inventory.</td></tr>';
    }
};

document.getElementById('inv-search')?.addEventListener('input', () => {
    // Debounce basic
    clearTimeout(window.invSearchTimeout);
    window.invSearchTimeout = setTimeout(loadInventory, 300);
});

// -- BATCH MANAGEMENT --
const openManageBatches = async (drugId, drugName) => {
    document.getElementById('batch-drug-id').value = drugId;
    document.getElementById('batch-drug-name').innerText = drugName;
    document.getElementById('form-add-batch').reset();
    await loadBatchesForDrug(drugId);
    openModal('modal-batches');
};

const loadBatchesForDrug = async (drugId) => {
    const tbody = document.getElementById('batches-table-body');
    tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4">Loading...</td></tr>';
    
    try {
        const batches = await db.batches.where('drugId').equals(drugId).toArray();
        // Sort by expiry date (FEFO)
        batches.sort((a, b) => new Date(a.expiryDate) - new Date(b.expiryDate));
        
        tbody.innerHTML = '';
        if(batches.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center p-4 text-gray-500">No batches recorded for this drug.</td></tr>';
            return;
        }

        const today = new Date();
        const ninetyDaysFromNow = new Date();
        ninetyDaysFromNow.setDate(today.getDate() + 90);

        batches.forEach(b => {
            const expDate = new Date(b.expiryDate);
            let rowClass = '';
            let expClass = '';
            
            if(expDate < today) {
                rowClass = 'bg-red-50/50';
                expClass = 'text-red-600 font-bold (Expired)';
            } else if (expDate <= ninetyDaysFromNow) {
                rowClass = 'bg-orange-50/50';
                expClass = 'text-orange-600 font-medium (Expiring Soon)';
            }

            tbody.innerHTML += `
                <tr class="${rowClass}">
                    <td class="p-2 text-gray-800 font-medium">${b.batchNumber}</td>
                    <td class="p-2 ${expClass}">${b.expiryDate}</td>
                    <td class="p-2 text-right text-gray-600">${formatCurrency(b.costPrice)}</td>
                    <td class="p-2 text-right text-green-700 font-medium">${formatCurrency(b.sellingPrice)}</td>
                    <td class="p-2 text-center font-bold ${b.qty <= 0 ? 'text-red-500' : 'text-gray-800'}">${b.qty}</td>
                    <td class="p-2 text-center">
                        <button onclick="deleteBatch(${b.id}, ${drugId})" class="text-red-500 hover:text-red-700" title="Delete Batch"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            `;
        });
    } catch(e) {
        console.error(e);
        showToast('Error loading batches', 'error');
    }
};

const saveBatch = async () => {
    const drugId = parseInt(document.getElementById('batch-drug-id').value);
    const batchNumber = document.getElementById('batch-number').value.trim();
    const expiryDate = document.getElementById('batch-expiry').value;
    const qty = parseInt(document.getElementById('batch-qty').value);
    const costPrice = parseFloat(document.getElementById('batch-cost').value);
    const sellingPrice = parseFloat(document.getElementById('batch-sell').value);

    try {
        await db.batches.add({
            drugId, batchNumber, expiryDate, qty, costPrice, sellingPrice
        });
        showToast('Batch added successfully', 'success');
        document.getElementById('form-add-batch').reset();
        loadBatchesForDrug(drugId);
        loadInventory(); // Update total qty in background
    } catch (e) {
        showToast('Error saving batch', 'error');
    }
};

const deleteBatch = async (batchId, drugId) => {
    if(confirm('Are you sure you want to delete this batch?')) {
        await db.batches.delete(batchId);
        showToast('Batch deleted', 'success');
        loadBatchesForDrug(drugId);
        loadInventory();
    }
};

// ==========================================
// 6. POS LOGIC
// ==========================================
const searchInput = document.getElementById('pos-search');
const searchResults = document.getElementById('pos-search-results');

searchInput.addEventListener('input', async (e) => {
    const query = e.target.value.toLowerCase().trim();
    if(query.length < 2) {
        searchResults.classList.add('hidden');
        return;
    }

    try {
        const drugs = await db.drugs.toArray();
        const matches = drugs.filter(d => 
            d.brandName.toLowerCase().includes(query) || 
            d.genericName.toLowerCase().includes(query)
        );

        searchResults.innerHTML = '';
        if(matches.length === 0) {
            searchResults.innerHTML = '<div class="p-4 text-gray-500 text-center text-sm">No items found</div>';
        } else {
            for(const m of matches) {
                // Get available batches
                const batches = await db.batches.where('drugId').equals(m.id).toArray();
                const availableBatches = batches.filter(b => b.qty > 0).sort((a, b) => new Date(a.expiryDate) - new Date(b.expiryDate));
                
                const totalAvailable = availableBatches.reduce((sum, b) => sum + b.qty, 0);
                
                // Get qty already in cart for this drug to adjust total available
                const inCartQty = currentCart.filter(item => item.drugId === m.id).reduce((sum, item) => sum + item.qty, 0);
                const actualAvailable = totalAvailable - inCartQty;

                const itemDiv = document.createElement('div');
                itemDiv.className = `p-3 border-b border-gray-100 hover:bg-blue-50 cursor-pointer flex justify-between items-center ${actualAvailable <= 0 ? 'opacity-50' : ''}`;
                itemDiv.innerHTML = `
                    <div>
                        <div class="font-medium text-gray-800">${m.brandName} ${m.dosage ? `(${m.dosage})` : ''}</div>
                        <div class="text-xs text-gray-500">${m.genericName || m.type}</div>
                    </div>
                    <div class="text-right">
                        ${totalAvailable > 0 
                            ? `<div class="text-sm font-bold text-green-600">${formatCurrency(availableBatches[0].sellingPrice)} ${availableBatches.length > 1 ? '<span class="text-xs text-gray-400"> (Starts from)</span>' : ''}</div>
                               <div class="text-xs text-gray-500">Stock: ${actualAvailable}</div>`
                            : `<div class="text-xs font-bold text-red-500 uppercase mt-2">Out of stock</div>`
                        }
                    </div>
                `;
                
                if(actualAvailable > 0) {
                    itemDiv.onclick = function(e) {
                        if(this.classList.contains('qty-mode')) return;
                        this.classList.add('qty-mode');
                        this.classList.remove('hover:bg-blue-50', 'cursor-pointer', 'flex', 'justify-between', 'items-center');
                        this.classList.add('bg-blue-50', 'block');
                        
                        this.innerHTML = `
                            <div class="flex flex-col gap-2">
                                <div class="flex justify-between items-center">
                                    <div>
                                        <span class="font-bold text-blue-800 text-sm">${m.brandName}</span>
                                    </div>
                                    <span class="text-xs text-gray-600">Stock: <span class="font-bold text-gray-800" id="selected-max-stock-${m.id}">${actualAvailable}</span></span>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <select id="pos-batch-select-${m.id}" class="w-full px-2 py-1.5 text-sm border border-blue-200 rounded focus:outline-none focus:ring-1 focus:ring-blue-500">
                                        <option value="auto">Auto Select (Oldest First)</option>
                                        ${availableBatches.map(b => {
                                            const qtyInCart = currentCart.filter(item => item.batchId === b.id).reduce((sum, item) => sum + item.qty, 0);
                                            const bActual = b.qty - qtyInCart;
                                            if(bActual > 0) {
                                                return '<option value="' + b.id + '">' + b.batchNumber + ' - Exp: ' + b.expiryDate + ' (Stock: ' + bActual + ')</option>';
                                            }
                                            return '';
                                        }).join('')}
                                    </select>
                                    <div class="flex gap-2 items-center">
                                        <input type="number" min="1" max="${actualAvailable}" value="1" class="flex-1 px-3 py-1.5 text-center font-bold border border-blue-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 inline-qty-input">
                                        <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-lg font-bold text-sm shadow-sm inline-add-btn whitespace-nowrap">
                                            <i class="fa-solid fa-plus mr-1"></i> Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `;
                        
                        const batchSelect = this.querySelector(`#pos-batch-select-${m.id}`);
                        const qtyInput = this.querySelector('.inline-qty-input');
                        const addBtn = this.querySelector('.inline-add-btn');
                        const stockDisplay = this.querySelector(`#selected-max-stock-${m.id}`);
                        
                        batchSelect.onchange = (ev) => {
                            ev.stopPropagation();
                            if(batchSelect.value === 'auto') {
                                qtyInput.max = actualAvailable;
                                stockDisplay.innerText = actualAvailable;
                                if(parseInt(qtyInput.value) > actualAvailable) qtyInput.value = actualAvailable;
                            } else {
                                const selectedBId = parseInt(batchSelect.value);
                                const selectedB = availableBatches.find(b => b.id === selectedBId);
                                const qtyInCart = currentCart.filter(item => item.batchId === selectedBId).reduce((sum, item) => sum + item.qty, 0);
                                const bActual = selectedB.qty - qtyInCart;
                                qtyInput.max = bActual;
                                stockDisplay.innerText = bActual;
                                if(parseInt(qtyInput.value) > bActual) qtyInput.value = bActual;
                            }
                        };
                        batchSelect.onclick = (ev) => ev.stopPropagation();
                        
                        setTimeout(() => {
                            qtyInput.focus();
                            qtyInput.select();
                        }, 50);

                        const confirmAdd = async () => {
                            const qty = parseInt(qtyInput.value);
                            const maxAllowed = parseInt(qtyInput.max);
                            if(qty > 0 && qty <= maxAllowed) {
                                if(batchSelect.value === 'auto') {
                                    await addToCartMultiBatch(m, qty);
                                } else {
                                    const selectedBId = parseInt(batchSelect.value);
                                    const selectedB = availableBatches.find(b => b.id === selectedBId);
                                    addToCartSingleBatch(m, selectedB, qty);
                                }
                                searchInput.value = '';
                                searchResults.classList.add('hidden');
                                searchInput.focus();
                            } else {
                                showToast('Invalid quantity or exceeds stock', 'error');
                            }
                        };

                        addBtn.onclick = (ev) => {
                            ev.stopPropagation();
                            confirmAdd();
                        };
                        
                        qtyInput.onclick = (ev) => ev.stopPropagation();
                        qtyInput.onkeydown = (ev) => {
                            if(ev.key === 'Enter') {
                                ev.preventDefault();
                                confirmAdd();
                            }
                        };
                    };
                }
                
                searchResults.appendChild(itemDiv);
            }
        }
        searchResults.classList.remove('hidden');

    } catch(e) {
        console.error("Search error", e);
    }
});

// Hide search results when clicking outside
document.addEventListener('click', (e) => {
    if(!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
    }
});

// Removed loadPOSQuickItems as fast moving grid is deleted.

const addToCartMultiBatch = async (drug, qtyToAdd) => {
    const batches = await db.batches.where('drugId').equals(drug.id).toArray();
    const availableBatches = batches.filter(b => b.qty > 0).sort((a, b) => new Date(a.expiryDate) - new Date(b.expiryDate));
    
    let remainingQty = qtyToAdd;
    
    for (const batch of availableBatches) {
        if (remainingQty <= 0) break;
        
        const existingIndex = currentCart.findIndex(item => item.batchId === batch.id);
        const qtyInCartForBatch = existingIndex > -1 ? currentCart[existingIndex].qty : 0;
        
        const availableInBatch = batch.qty - qtyInCartForBatch;
        if (availableInBatch <= 0) continue; 
        
        const takeQty = Math.min(remainingQty, availableInBatch);
        
        if (existingIndex > -1) {
            currentCart[existingIndex].qty += takeQty;
        } else {
            currentCart.push({
                drugId: drug.id,
                brandName: drug.brandName,
                batchId: batch.id,
                batchNumber: batch.batchNumber,
                unitPrice: batch.sellingPrice,
                costPrice: batch.costPrice,
                maxQty: batch.qty,
                qty: takeQty
            });
        }
        remainingQty -= takeQty;
    }
    
    if (remainingQty > 0) {
        showToast(`Could only add partial quantity. Not enough stock.`, 'warning');
    }
    
    renderCart();
};

const addToCartSingleBatch = (drug, batch, qtyToAdd) => {
    const existingIndex = currentCart.findIndex(item => item.batchId === batch.id);
    if (existingIndex > -1) {
        currentCart[existingIndex].qty += qtyToAdd;
    } else {
        currentCart.push({
            drugId: drug.id,
            brandName: drug.brandName,
            batchId: batch.id,
            batchNumber: batch.batchNumber,
            unitPrice: batch.sellingPrice,
            costPrice: batch.costPrice,
            maxQty: batch.qty,
            qty: qtyToAdd
        });
    }
    renderCart();
};

const renderCart = () => {
    const container = document.getElementById('cart-items');
    
    if(currentCart.length === 0) {
        container.innerHTML = `
            <div class="h-full flex flex-col items-center justify-center text-gray-400 opacity-50 space-y-3">
                <i class="fa-solid fa-basket-shopping text-4xl"></i>
                <p class="text-sm">Cart is empty</p>
            </div>
        `;
        updateTotals();
        return;
    }

    container.innerHTML = '';
    currentCart.forEach((item, index) => {
        const itemTotal = item.qty * item.unitPrice;
        const div = document.createElement('div');
        div.className = 'bg-white p-2 rounded shadow-sm border border-gray-200 mb-2 flex flex-col gap-2 relative';
        div.innerHTML = `
            <div class="flex justify-between items-center pr-6 mb-1">
                <div class="flex-1">
                    <h4 class="text-sm font-semibold text-gray-800 leading-tight">${item.brandName} <span class="text-xs text-gray-500 font-normal">(${item.batchNumber})</span></h4>
                    <p class="text-xs text-gray-500 mt-0.5">${formatCurrency(item.unitPrice)} per unit</p>
                </div>
                <div class="flex items-center border border-gray-300 rounded overflow-hidden shadow-sm mx-2">
                    <button onclick="updateCartQty(${index}, -1)" class="px-2 py-1 bg-gray-100 hover:bg-gray-200 text-gray-600"><i class="fa-solid fa-minus text-xs"></i></button>
                    <input type="number" value="${item.qty}" class="w-10 text-center text-sm font-medium py-1 focus:outline-none bg-white" readonly>
                    <button onclick="updateCartQty(${index}, 1)" class="px-2 py-1 bg-gray-100 hover:bg-gray-200 text-gray-600"><i class="fa-solid fa-plus text-xs"></i></button>
                </div>
                <div class="font-bold text-blue-700 text-sm min-w-[70px] text-right">${formatCurrency(itemTotal)}</div>
            </div>
            <button onclick="removeFromCart(${index})" class="absolute top-2 right-2 text-red-400 hover:text-red-600"><i class="fa-solid fa-xmark"></i></button>
        `;
        container.appendChild(div);
    });
    
    // Auto scroll to bottom
    container.scrollTop = container.scrollHeight;
    updateTotals();
};

const updateCartQty = (index, change) => {
    const item = currentCart[index];
    const newQty = item.qty + change;
    
    if(newQty > 0 && newQty <= item.maxQty) {
        item.qty = newQty;
        renderCart();
    } else if (newQty > item.maxQty) {
        showToast(`Only ${item.maxQty} available in stock`, 'warning');
    }
};

const removeFromCart = (index) => {
    currentCart.splice(index, 1);
    renderCart();
};

const clearCart = () => {
    currentCart = [];
    document.getElementById('cart-discount-val').value = '0';
    clearPOSCustomer();
    document.getElementById('pos-doctor').value = '';
    renderCart();
    
    // Generate new invoice number sequentially
    generateInvoiceNumber();
};

const generateInvoiceNumber = async () => {
    try {
        const lastSale = await db.sales.orderBy('id').last();
        let nextNo = 1;
        if (lastSale && lastSale.invoiceNumber) {
            const matches = lastSale.invoiceNumber.match(/INV-(\d+)/);
            if (matches) {
                nextNo = parseInt(matches[1], 10) + 1;
            } else {
                nextNo = (lastSale.id || 0) + 1;
            }
        }
        window.currentInvoiceNo = 'INV-' + nextNo.toString().padStart(6, '0');
        document.getElementById('pos-invoice-display').innerText = window.currentInvoiceNo;
    } catch (e) {
        window.currentInvoiceNo = 'INV-000001';
        document.getElementById('pos-invoice-display').innerText = window.currentInvoiceNo;
    }
};

// Event listeners for discount updates
document.getElementById('cart-discount-val').addEventListener('input', updateTotals);
document.getElementById('cart-discount-type').addEventListener('change', updateTotals);

function updateTotals() {
    const subtotal = currentCart.reduce((sum, item) => sum + (item.qty * item.unitPrice), 0);
    const totalCost = currentCart.reduce((sum, item) => sum + (item.qty * item.costPrice), 0);
    
    let discountVal = parseFloat(document.getElementById('cart-discount-val').value) || 0;
    const discountType = document.getElementById('cart-discount-type').value;
    
    let discountAmount = 0;
    if(discountType === '%') {
        discountAmount = subtotal * (discountVal / 100);
    } else {
        discountAmount = discountVal;
    }
    
    const total = Math.max(0, subtotal - discountAmount);
    
    document.getElementById('cart-subtotal').innerText = formatCurrency(subtotal);
    document.getElementById('cart-total').innerText = formatCurrency(total);
    document.getElementById('checkout-total-display').innerText = formatCurrency(total);
    
    // Update balance if cash tendered is changed
    updateCheckoutBalance();
    
    return { subtotal, discountAmount, total, totalCost };
}

// Global State for split payments
window.checkoutPayments = [];
window.checkoutChangeDue = 0;

window.checkoutCustomer = null;

const addPaymentMethod = () => {
    const method = document.getElementById('checkout-pay-method').value;
    const amount = parseFloat(document.getElementById('checkout-pay-amount').value) || 0;
    
    if (amount <= 0) return showToast('Enter a valid amount', 'warning');
    
    window.checkoutPayments.push({ method, amount });
    document.getElementById('checkout-pay-amount').value = '';
    renderCheckoutPayments();
};

const removePaymentMethod = (index) => {
    window.checkoutPayments.splice(index, 1);
    renderCheckoutPayments();
};

const renderCheckoutPayments = () => {
    const list = document.getElementById('checkout-payments-list');
    list.innerHTML = '';
    
    window.checkoutPayments.forEach((p, i) => {
        let icon = 'fa-money-bill';
        if (p.method === 'card') icon = 'fa-credit-card';
        if (p.method === 'bank') icon = 'fa-building-columns';
        if (p.method === 'qr') icon = 'fa-qrcode';
        
        list.innerHTML += `
            <div class="flex justify-between items-center bg-white p-2 border border-gray-200 rounded-lg">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center text-blue-600">
                        <i class="fa-solid ${icon}"></i>
                    </div>
                    <span class="text-sm font-bold text-gray-700 capitalize">${p.method}</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="font-bold text-gray-800">${formatCurrency(p.amount)}</span>
                    <button onclick="removePaymentMethod(${i})" class="text-red-400 hover:text-red-600"><i class="fa-solid fa-xmark"></i></button>
                </div>
            </div>
        `;
    });
    
    updateCheckoutBalance();
};

const openCheckoutModal = async () => {
    if(currentCart.length === 0) return showToast('Cart is empty', 'error');
    
    // Check if customer is selected
    const customerIdStr = document.getElementById('pos-customer-id').value;
    const walletSection = document.getElementById('checkout-wallet-section');
    
    if(customerIdStr) {
        window.checkoutCustomer = await db.customers.get(parseInt(customerIdStr));
        if(window.checkoutCustomer) {
            document.getElementById('checkout-avail-points').innerText = window.checkoutCustomer.loyaltyPoints || 0;
            document.getElementById('checkout-points-val').innerText = window.checkoutCustomer.loyaltyPoints || 0; // 1 pt = 1 rs
            document.getElementById('checkout-avail-credit').innerText = formatCurrency(window.checkoutCustomer.storeCredit || 0);
            
            document.getElementById('checkout-use-points').checked = false;
            document.getElementById('checkout-use-credit').checked = false;
            
            walletSection.classList.remove('hidden');
        } else {
            walletSection.classList.add('hidden');
        }
    } else {
        window.checkoutCustomer = null;
        walletSection.classList.add('hidden');
    }

    document.getElementById('checkout-add-points-amount').value = '';
    document.getElementById('checkout-add-credit-wrapper').classList.add('hidden');
    window.checkoutCalcBalance = 0;
    
    window.checkoutPayments = [];
    document.getElementById('checkout-pay-method').value = 'cash';
    document.getElementById('checkout-pay-amount').value = '';
    renderCheckoutPayments();

    updateTotals();
    
    openModal('modal-checkout');
    updateCheckoutBalance();
    
    setTimeout(() => {
        const input = document.getElementById('checkout-pay-amount');
        if(input) input.focus();
    }, 100);
};

const updateCheckoutBalance = () => {
    const subtotal = currentCart.reduce((sum, item) => sum + (item.qty * item.unitPrice), 0);
    let discountVal = parseFloat(document.getElementById('cart-discount-val').value) || 0;
    const discountType = document.getElementById('cart-discount-type').value;
    let baseDiscount = discountType === '%' ? subtotal * (discountVal / 100) : discountVal;
    
    let remainingTotal = Math.max(0, subtotal - baseDiscount);
    
    // Loyalty deductions
    let pointsDiscount = 0;
    let creditDiscount = 0;
    
    if(window.checkoutCustomer) {
        if(document.getElementById('checkout-use-points')?.checked) {
            pointsDiscount = Math.min(window.checkoutCustomer.loyaltyPoints || 0, remainingTotal);
            remainingTotal -= pointsDiscount;
        }
        
        if(document.getElementById('checkout-use-credit')?.checked) {
            creditDiscount = Math.min(window.checkoutCustomer.storeCredit || 0, remainingTotal);
            remainingTotal -= creditDiscount;
        }
    }
    
    let totalPaid = window.checkoutPayments.reduce((sum, p) => sum + p.amount, 0);
    
    const remainingToPay = Math.max(0, remainingTotal - totalPaid);
    const changeDue = Math.max(0, totalPaid - remainingTotal);
    window.checkoutChangeDue = changeDue;
    
    document.getElementById('checkout-remaining-display').innerText = formatCurrency(remainingToPay);
    
    if (remainingToPay > 0) {
         document.getElementById('checkout-pay-amount').placeholder = remainingToPay.toFixed(2);
    } else {
         document.getElementById('checkout-pay-amount').placeholder = 'Amount';
    }
    
    const changeSection = document.getElementById('checkout-change-section');
    if (changeDue > 0) {
        changeSection.classList.remove('hidden');
        document.getElementById('checkout-cash-change').innerText = formatCurrency(changeDue);
        
        const addCreditWrapper = document.getElementById('checkout-add-credit-wrapper');
        if(window.checkoutCustomer) {
            addCreditWrapper.classList.remove('hidden');
        } else {
            addCreditWrapper.classList.add('hidden');
            document.getElementById('checkout-add-points-amount').value = '';
        }
    } else {
        changeSection.classList.add('hidden');
    }
    
    // Display total dynamically to reflect loyalty deductions
    document.getElementById('checkout-total-display').innerText = 'Rs. ' + formatCurrency(remainingTotal);
    
    return { remainingTotal, pointsDiscount, creditDiscount, remainingToPay, changeDue };
};

// Listeners removed since UI changed

const printReceipt = (sale, items) => {
    let receiptHTML = `
        <div style="text-align:center; border-bottom:1px dashed #000; padding-bottom:10px; margin-bottom:10px;">
            <h2 style="margin:0; font-size:18px;">NEXUS PHARMACY</h2>
            <p style="margin:0; font-size:12px;">123 Main Street, City</p>
            <p style="margin:0; font-size:12px;">Tel: 011-2345678</p>
        </div>
        <div style="margin-bottom:10px; font-size:12px;">
            <p style="margin:2px 0;">Invoice: ${sale.invoiceNumber}</p>
            <p style="margin:2px 0;">Date: ${formatDate(sale.dateTime)}</p>
            ${sale.customer ? `<p style="margin:2px 0;">Customer: ${sale.customer}</p>` : ''}
        </div>
        <table style="width:100%; font-size:12px; border-collapse: collapse; margin-bottom:10px;">
            <tr style="border-bottom:1px dashed #000;">
                <th style="text-align:left; padding:2px 0;">Item</th>
                <th style="text-align:right; padding:2px 0;">Qty</th>
                <th style="text-align:right; padding:2px 0;">Total</th>
            </tr>
    `;

    items.forEach(i => {
        receiptHTML += `
            <tr>
                <td style="padding:2px 0;">${i.brandName} <span style="font-size:10px;">(${i.batchNumber || '-'})</span></td>
                <td style="text-align:right; padding:2px 0;">${i.qty}</td>
                <td style="text-align:right; padding:2px 0;">${(i.qty * i.unitPrice).toFixed(2)}</td>
            </tr>
