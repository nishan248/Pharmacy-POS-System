    });
};

const viewImage = (base64) => {
    document.getElementById('viewer-image').src = base64;
    openModal('modal-image-viewer');
};

document.getElementById('cust-search')?.addEventListener('input', () => {
    clearTimeout(window.custTimeout);
    window.custTimeout = setTimeout(loadCustomers, 300);
});

// ==========================================
// 13. EXPIRY MANAGEMENT
// ==========================================
window.switchExpiryTab = (tab) => {
    document.getElementById('tab-expiry-alerts').className = tab === 'alerts' ? 'px-4 py-1.5 text-sm font-medium rounded-md bg-white shadow-sm text-blue-600 transition-all flex-1 md:flex-none' : 'px-4 py-1.5 text-sm font-medium rounded-md text-gray-500 hover:text-gray-700 transition-all flex-1 md:flex-none';
    document.getElementById('tab-expiry-history').className = tab === 'history' ? 'px-4 py-1.5 text-sm font-medium rounded-md bg-white shadow-sm text-blue-600 transition-all flex-1 md:flex-none' : 'px-4 py-1.5 text-sm font-medium rounded-md text-gray-500 hover:text-gray-700 transition-all flex-1 md:flex-none';
    
    document.getElementById('expiry-alerts-view').classList.toggle('hidden', tab !== 'alerts');
    document.getElementById('expiry-history-view').classList.toggle('hidden', tab !== 'history');
    document.getElementById('expiry-filter-container').classList.toggle('hidden', tab !== 'alerts');
    
    if (tab === 'history') {
        loadDisposalHistory();
    } else {
        loadExpiryManagement();
    }
};

window.loadExpiryManagement = async () => {
    const filterVal = document.getElementById('expiry-filter').value;
    const searchVal = document.getElementById('expiry-search').value.toLowerCase().trim();
    const tbody = document.getElementById('expiry-table-body');
    if(!tbody) return;

    try {
        const allBatches = await db.batches.filter(b => b.qty > 0).toArray();
        const allDrugs = await db.drugs.toArray();
        const allSuppliers = await db.suppliers.toArray();
        const today = new Date();
        today.setHours(0,0,0,0);
        
        let totalExpiredValue = 0;
        let totalExpiredItems = 0;
        let expiring30Days = 0;

        // Calculate Summary Cards
        allBatches.forEach(b => {
            const expDate = new Date(b.expiryDate);
            const daysDiff = (expDate - today) / (1000 * 60 * 60 * 24);
            
            if (daysDiff < 0) {
                totalExpiredItems++;
                totalExpiredValue += (b.unitCost || 0) * b.qty;
            } else if (daysDiff <= 30) {
                expiring30Days++;
            }
        });

        document.getElementById('expiry-total-loss').innerText = formatCurrency(totalExpiredValue);
        document.getElementById('expiry-total-items').innerText = totalExpiredItems;
        document.getElementById('expiry-30days').innerText = expiring30Days;

        // Filter for Table
        let targetBatches = allBatches.filter(b => {
            const drug = allDrugs.find(d => d.id === b.drugId);
            const drugName = drug ? drug.brandName.toLowerCase() : '';
            const batchNo = (b.batchNumber || '').toLowerCase();
            
            if (searchVal && !drugName.includes(searchVal) && !batchNo.includes(searchVal)) {
                return false;
            }

            const expDate = new Date(b.expiryDate);
            const daysDiff = (expDate - today) / (1000 * 60 * 60 * 24);
            
            if (filterVal === 'all') return true;
            if (filterVal === '0') return daysDiff < 0;
            return daysDiff >= 0 && daysDiff <= parseInt(filterVal);
        });

        targetBatches.sort((a,b) => new Date(a.expiryDate) - new Date(b.expiryDate));

        tbody.innerHTML = '';
        if(targetBatches.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center p-6 text-gray-500">No batches match this criteria.</td></tr>`;
            return;
        }

        targetBatches.forEach(b => {
            const drug = allDrugs.find(d => d.id === b.drugId);
            const supplier = allSuppliers.find(s => s.id == b.supplierId);
            const supplierName = supplier ? supplier.name : 'Unknown Supplier';
            const expDate = new Date(b.expiryDate);
            const isExpired = expDate < today;
            const estValue = (b.unitCost || 0) * b.qty;
            
            tbody.innerHTML += `
                <tr class="${isExpired ? 'bg-red-50/50' : 'bg-orange-50/50'}">
                    <td class="p-4 font-medium text-gray-800">${drug ? drug.brandName : 'Unknown'}</td>
                    <td class="p-4 text-gray-600">${b.batchNumber || 'N/A'}<br><span class="text-xs text-gray-500"><i class="fa-solid fa-truck mr-1"></i>${supplierName}</span></td>
                    <td class="p-4 font-bold ${isExpired ? 'text-red-600' : 'text-orange-600'}">${b.expiryDate}</td>
                    <td class="p-4 text-gray-800 font-medium text-center">${b.qty}</td>
                    <td class="p-4 text-gray-800 font-medium text-right">${formatCurrency(estValue)}</td>
                    <td class="p-4 text-center">
                        <button onclick="openDisposeModal(${b.id}, 'dispose')" class="text-red-600 hover:text-red-800 text-sm font-medium border border-red-200 px-2 py-1 rounded bg-white shadow-sm mr-1" title="Dispose Items"><i class="fa-solid fa-trash-can"></i></button>
                        <button onclick="openDisposeModal(${b.id}, 'return')" class="text-blue-600 hover:text-blue-800 text-sm font-medium border border-blue-200 px-2 py-1 rounded bg-white shadow-sm" title="Return to Supplier"><i class="fa-solid fa-truck-arrow-right"></i></button>
                    </td>
                </tr>
            `;
        });
    } catch(e) { console.error('Error loading expiry management', e); }
};

window.openDisposeModal = (batchId, type) => {
    document.getElementById('dispose-batch-id').value = batchId;
    document.getElementById('dispose-type').value = type;
    document.getElementById('dispose-notes').value = '';
    
    if (type === 'return') {
        document.getElementById('dispose-modal-title').innerText = 'Return Stock to Supplier';
        document.getElementById('dispose-modal-desc').innerText = 'You are about to remove this batch from stock and mark it as returned. This action will be recorded in the ledger.';
        document.getElementById('btn-confirm-dispose').className = 'px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-md';
        document.getElementById('btn-confirm-dispose').innerText = 'Confirm Return';
    } else {
        document.getElementById('dispose-modal-title').innerText = 'Dispose Stock';
        document.getElementById('dispose-modal-desc').innerText = 'You are about to permanently remove this batch from stock. The loss will be recorded.';
        document.getElementById('btn-confirm-dispose').className = 'px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 shadow-md';
        document.getElementById('btn-confirm-dispose').innerText = 'Confirm Disposal';
    }
    
    openModal('modal-dispose');
};

window.confirmDisposal = async () => {
    const batchId = parseInt(document.getElementById('dispose-batch-id').value);
    const type = document.getElementById('dispose-type').value;
    const notes = document.getElementById('dispose-notes').value.trim();
    
    if(!notes) return showToast('Please enter a reason or notes.', 'error');
    
    try {
        await db.transaction('rw', db.batches, db.disposals, db.stock_ledger, async () => {
            const batch = await db.batches.get(batchId);
            if(!batch) throw new Error("Batch not found");
            
            const qty = batch.qty;
            const unitCost = batch.unitCost || 0;
            const totalLoss = qty * unitCost;
            
            // 1. Add to disposals table
            await db.disposals.add({
                date: new Date().toISOString(),
                type: type, // 'dispose' or 'return'
                drugId: batch.drugId,
                batchId: batch.id,
                supplierId: batch.supplierId,
                qty: qty,
                unitCost: unitCost,
                totalLoss: totalLoss,
                notes: notes
            });
            
            // 2. Add to stock ledger
            await db.stock_ledger.add({
                date: new Date().toISOString(),
                drugId: batch.drugId,
                batchId: batch.id,
                transactionType: type === 'return' ? 'RETURN' : 'DISPOSAL',
                qtyOut: qty,
                balance: 0, // Since we are clearing the batch
                reference: notes
            });
            
            // 3. Update batch qty to 0
            await db.batches.update(batchId, { qty: 0 });
        });
        
        showToast(type === 'return' ? 'Stock returned successfully' : 'Stock disposed successfully', 'success');
        closeModal('modal-dispose');
        loadExpiryManagement();
        loadInventory();
        loadDashboard();
    } catch (e) {
        showToast('Error processing: ' + e.message, 'error');
        console.error(e);
    }
};

window.loadDisposalHistory = async () => {
    const tbody = document.getElementById('expiry-history-body');
    const searchVal = document.getElementById('expiry-search').value.toLowerCase().trim();
    if(!tbody) return;
    
    try {
        const allDisposals = await db.disposals.reverse().toArray();
        const allDrugs = await db.drugs.toArray();
        const allBatches = await db.batches.toArray();
        
        let targetDisposals = allDisposals;
        
        if (searchVal) {
            targetDisposals = targetDisposals.filter(d => {
                const drug = allDrugs.find(dr => dr.id === d.drugId);
                const batch = allBatches.find(b => b.id === d.batchId);
                const drugName = drug ? drug.brandName.toLowerCase() : '';
                const batchNo = batch ? (batch.batchNumber || '').toLowerCase() : '';
                return drugName.includes(searchVal) || batchNo.includes(searchVal);
            });
        }
        
        tbody.innerHTML = '';
        if(targetDisposals.length === 0) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center p-6 text-gray-500">No history found.</td></tr>`;
            return;
        }
        
        targetDisposals.forEach(d => {
            const drug = allDrugs.find(dr => dr.id === d.drugId);
            const batch = allBatches.find(b => b.id === d.batchId);
            
            const dateStr = new Date(d.date).toLocaleDateString() + ' ' + new Date(d.date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            const typeBadge = d.type === 'return' 
                ? '<span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded-full font-medium">RETURNED</span>'
                : '<span class="px-2 py-1 bg-red-100 text-red-800 text-xs rounded-full font-medium">DISPOSED</span>';
                
            tbody.innerHTML += `
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 text-gray-600 text-xs">${dateStr}</td>
                    <td class="p-4">${typeBadge}</td>
                    <td class="p-4">
                        <div class="font-medium text-gray-800">${drug ? drug.brandName : 'Unknown'}</div>
                        <div class="text-xs text-gray-500">Batch: ${batch ? batch.batchNumber : 'N/A'}</div>
                    </td>
                    <td class="p-4 text-center font-bold text-gray-700">${d.qty}</td>
                    <td class="p-4 text-right font-medium text-gray-800">${formatCurrency(d.totalLoss)}</td>
                    <td class="p-4 text-gray-500 text-xs italic max-w-xs truncate" title="${d.notes}">${d.notes}</td>
                </tr>
            `;
        });
    } catch(e) { console.error('Error loading history', e); }
};

