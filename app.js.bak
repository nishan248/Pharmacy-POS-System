    receiptHTML += `
        </table>
        <div style="text-align:right; font-size:12px; border-top:1px dashed #000; padding-top:5px; margin-bottom:10px;">
            <p style="margin:2px 0;">Subtotal: ${sale.totalAmount.toFixed(2)}</p>
            <p style="margin:2px 0;">Discount: ${sale.discount.toFixed(2)}</p>
            <h3 style="margin:5px 0; font-size:16px;">Total: Rs. ${sale.netAmount.toFixed(2)}</h3>
            ${sale.paymentMethod === 'split' && sale.splitPayments 
                ? sale.splitPayments.map(p => `<p style="margin:2px 0;">${p.method.toUpperCase()}: ${p.amount.toFixed(2)}</p>`).join('')
                : `<p style="margin:2px 0;">Method: ${(sale.paymentMethod || '').toUpperCase()}</p>`}
        </div>
        <div style="text-align:center; font-size:12px; border-top:1px dashed #000; padding-top:10px;">
            <p style="margin:0;">Thank you for your business!</p>
            <p style="margin:0;">Get well soon.</p>
        </div>
    `;

    document.getElementById('print-receipt-container').innerHTML = receiptHTML;
    // window.print(); removed as requested
};

// ==========================================
// 7. DASHBOARD LOGIC
// ==========================================
const loadDashboard = async () => {
    try {
        const todayStr = new Date().toISOString().split('T')[0];
        
        // 1. Today's Sales & Profit
        const allSales = await db.sales.toArray();
        const todaySales = allSales.filter(s => s.dateTime.startsWith(todayStr));
        
        const totalSales = todaySales.reduce((sum, s) => sum + s.netAmount, 0);
        const totalProfit = todaySales.reduce((sum, s) => sum + (s.profit || 0), 0);
        
        document.getElementById('dash-sales').innerText = formatCurrency(totalSales);
        document.getElementById('dash-profit').innerText = formatCurrency(totalProfit);

        // 2. Inventory Alerts (Low Stock & Expiry)
        const allBatches = await db.batches.toArray();
        const allDrugs = await db.drugs.toArray();
        
        const today = new Date();
        const ninetyDays = new Date();
        ninetyDays.setDate(today.getDate() + 90);

        let expiringBatches = [];
        
        // Map batches to drugs to calculate total qty per drug
        let drugQtys = {};
        allDrugs.forEach(d => drugQtys[d.id] = 0);
        
        allBatches.forEach(b => {
            if (drugQtys[b.drugId] !== undefined) {
                drugQtys[b.drugId] += b.qty;
            } else {
                drugQtys[b.drugId] = b.qty;
            }
            
            const expDate = new Date(b.expiryDate);
            if(expDate <= ninetyDays && b.qty > 0) {
                const drug = allDrugs.find(d => d.id === b.drugId);
                expiringBatches.push({
                    drugName: drug ? drug.brandName : 'Unknown',
                    batchNumber: b.batchNumber,
                    expiryDate: b.expiryDate,
                    isExpired: expDate < today,
                    qty: b.qty
                });
            }
        });

        let lowStockCount = 0;
        let lowStockAlerts = [];
        
        for (const [dId, qty] of Object.entries(drugQtys)) {
            const drug = allDrugs.find(d => d.id == dId);
            const mbqThreshold = (drug && drug.mbq !== undefined) ? drug.mbq : 20;
            if (qty <= mbqThreshold) { // Threshold using MBQ
                lowStockCount++;
                lowStockAlerts.push({
                    drugName: drug ? drug.brandName : 'Unknown',
                    qty: qty
                });
            }
        }
        
        // Add completely out of stock drugs (qty = 0) that have no batches
        allDrugs.forEach(d => {
            if(drugQtys[d.id] === undefined) {
                lowStockCount++;
                lowStockAlerts.push({ drugName: d.brandName, qty: 0 });
            }
        });

        document.getElementById('dash-low-stock').innerText = lowStockCount;
        document.getElementById('dash-expiring').innerText = expiringBatches.length;

        // Render Alerts list
        const alertsContainer = document.getElementById('alerts-container');
        alertsContainer.innerHTML = '';
        
        if(expiringBatches.length === 0 && lowStockAlerts.length === 0) {
            alertsContainer.innerHTML = '<div class="text-center text-gray-400 mt-10 text-sm">No critical alerts.</div>';
        } else {
            expiringBatches.forEach(b => {
                alertsContainer.innerHTML += `
                    <div class="p-3 mb-2 rounded border ${b.isExpired ? 'bg-red-50 border-red-100' : 'bg-orange-50 border-orange-100'} flex items-start gap-3">
                        <i class="fa-solid fa-calendar-xmark mt-1 ${b.isExpired ? 'text-red-500' : 'text-orange-500'}"></i>
                        <div>
                            <p class="text-sm font-semibold ${b.isExpired ? 'text-red-800' : 'text-orange-800'}">${b.drugName}</p>
                            <p class="text-xs text-gray-600">Batch ${b.batchNumber} - ${b.isExpired ? 'EXPIRED ON' : 'Expiring:'} ${b.expiryDate}</p>
                        </div>
                    </div>
                `;
            });
            lowStockAlerts.forEach(a => {
                alertsContainer.innerHTML += `
                    <div class="p-3 mb-2 rounded border bg-yellow-50 border-yellow-100 flex items-start gap-3">
                        <i class="fa-solid fa-boxes-stacked mt-1 text-yellow-600"></i>
                        <div>
                            <p class="text-sm font-semibold text-yellow-800">${a.drugName}</p>
                            <p class="text-xs text-gray-600">Stock running low: ${a.qty} remaining</p>
                        </div>
                    </div>
                `;
            });
        }

        // 3. Render Chart
        renderSalesChart(allSales);

    } catch(e) {
        console.error("Dashboard error", e);
    }
};

const renderSalesChart = (allSales) => {
    const ctx = document.getElementById('salesChart').getContext('2d');
    
    // Calculate last 7 days sales
    const labels = [];
    const data = [];
    
    for(let i=6; i>=0; i--) {
        const d = new Date();
        d.setDate(d.getDate() - i);
        const dateStr = d.toISOString().split('T')[0];
        
        labels.push(d.toLocaleDateString('en-GB', {weekday: 'short'})); // Mon, Tue...
        
        const daySales = allSales.filter(s => s.dateTime.startsWith(dateStr)).reduce((sum, s) => sum + s.netAmount, 0);
        data.push(daySales);
    }

    if(salesChartInstance) salesChartInstance.destroy();

    salesChartInstance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Sales Revenue',
                data: data,
                borderColor: '#3b82f6',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { beginAtZero: true }
            }
        }
    });
};

// ==========================================
// ==========================================
// 8. REPORTS LOGIC
// ==========================================
window.handleReportTypeChange = () => {
    const reportType = document.getElementById('report-type').value;
    const dateFilterContainer = document.getElementById('report-date-filter-container');
    const customDateInputs = document.getElementById('custom-date-inputs');
    
    // Hide date filter for inventory and low stock as they are real-time status
    if (reportType === 'inventory' || reportType === 'low_stock') {
        dateFilterContainer.classList.add('hidden');
        customDateInputs.classList.add('hidden');
    } else {
        dateFilterContainer.classList.remove('hidden');
        if(document.getElementById('report-date-range').value === 'custom') {
            customDateInputs.classList.remove('hidden');
        }
    }
    
    // Reset table and summary
    document.getElementById('report-summary-container').innerHTML = '';
    document.getElementById('report-table-head').innerHTML = '';
    document.getElementById('report-table-body').innerHTML = '';
    document.getElementById('report-table-title').innerText = 'Select and Generate Report';
};

document.getElementById('report-date-range').addEventListener('change', (e) => {
    const customDiv = document.getElementById('custom-date-inputs');
    if(e.target.value === 'custom') {
        customDiv.classList.remove('hidden');
    } else {
        customDiv.classList.add('hidden');
    }
});

const getReportDateRange = () => {
    const rangeType = document.getElementById('report-date-range').value;
    let startDate = new Date();
    let endDate = new Date();
    
    startDate.setHours(0,0,0,0);
    endDate.setHours(23,59,59,999);

    if(rangeType === 'yesterday') {
        startDate.setDate(startDate.getDate() - 1);
        endDate.setDate(endDate.getDate() - 1);
    } else if (rangeType === 'this_week') {
        const day = startDate.getDay() || 7; // Get current day number, converting Sun. to 7
        if (day !== 1) startDate.setHours(-24 * (day - 1)); // Set to Monday
    } else if (rangeType === 'this_month') {
        startDate.setDate(1);
    } else if (rangeType === 'custom') {
        const customStart = document.getElementById('report-start-date').value;
        const customEnd = document.getElementById('report-end-date').value;
        if(customStart) startDate = new Date(customStart + 'T00:00:00');
        if(customEnd) endDate = new Date(customEnd + 'T23:59:59');
    }
    return { startDate, endDate };
};

const generateReport = async () => {
    const reportType = document.getElementById('report-type').value;
    
    try {
        if (reportType === 'sales') {
            await generateSalesReport();
        } else if (reportType === 'inventory') {
            await generateInventoryReport();
        } else if (reportType === 'reorder') {
            await generateReorderReport();
        } else if (reportType === 'expiry') {
            await generateExpiryReport();
        } else if (reportType === 'purchases') {
            await generatePurchasesReport();
        } else if (reportType === 'prescriptions') {
            await generatePrescriptionsReport();
        } else if (reportType === 'controlled') {
            await generateControlledReport();
        } else if (reportType === 'adjustments') {
            await generateAdjustmentsReport();
        } else if (reportType === 'business') {
            await generateBusinessReport();
        }
    } catch(e) {
        console.error(e);
        showToast('Error generating report', 'error');
    }
};

const generateSalesReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allSales = await db.sales.toArray();
    const filteredSales = allSales.filter(s => {
        const sDate = new Date(s.dateTime);
        return sDate >= startDate && sDate <= endDate;
    });

    let totalRevenue = 0;
    let cashSales = 0;
    let cardSales = 0;
    let bankSales = 0;
    let qrSales = 0;

    filteredSales.forEach(s => {
        totalRevenue += s.netAmount;
        if (s.splitPayments && s.splitPayments.length > 0) {
            s.splitPayments.forEach(p => {
                if (p.method === 'cash') cashSales += p.amount;
                if (p.method === 'card') cardSales += p.amount;
                if (p.method === 'bank') bankSales += p.amount;
                if (p.method === 'qr') qrSales += p.amount;
            });
        } else {
            if (s.paymentMethod === 'cash') cashSales += s.netAmount;
            if (s.paymentMethod === 'card') cardSales += s.netAmount;
            if (s.paymentMethod === 'bank') bankSales += s.netAmount;
            if (s.paymentMethod === 'qr') qrSales += s.netAmount;
        }
    });

    // Update Summary
    document.getElementById('report-summary-container').className = 'grid grid-cols-1 md:grid-cols-5 gap-4';
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm border-l-4 border-l-blue-500">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Total Revenue</p>
            <h2 class="text-2xl font-bold text-gray-800 mt-1">${formatCurrency(totalRevenue)}</h2>
        </div>
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm border-l-4 border-l-green-500">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Cash Sales</p>
            <h2 class="text-2xl font-bold text-green-600 mt-1">${formatCurrency(cashSales)}</h2>
        </div>
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm border-l-4 border-l-gray-500">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Card Sales</p>
            <h2 class="text-2xl font-bold text-gray-600 mt-1">${formatCurrency(cardSales)}</h2>
        </div>
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm border-l-4 border-l-purple-500">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">Bank Transfer</p>
            <h2 class="text-2xl font-bold text-purple-600 mt-1">${formatCurrency(bankSales)}</h2>
        </div>
        <div class="bg-white p-4 rounded-xl border border-gray-100 shadow-sm border-l-4 border-l-orange-500">
            <p class="text-xs text-gray-500 font-medium uppercase tracking-wider">QR Sales</p>
            <h2 class="text-2xl font-bold text-orange-600 mt-1">${formatCurrency(qrSales)}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Daily Sales Transactions';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Invoice</th>
            <th class="p-3 font-medium border-b border-gray-200">Date/Time</th>
            <th class="p-3 font-medium border-b border-gray-200">Total</th>
            <th class="p-3 font-medium border-b border-gray-200">Discount</th>
            <th class="p-3 font-medium border-b border-gray-200">Net</th>
            <th class="p-3 font-medium border-b border-gray-200">Method</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(filteredSales.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="p-4 text-center text-gray-500">No sales found for this period.</td></tr>';
        return;
    }

    filteredSales.sort((a,b) => new Date(b.dateTime) - new Date(a.dateTime));
    filteredSales.forEach(s => {
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-blue-600 font-bold cursor-pointer hover:underline" onclick="viewInvoice('${s.id}')">
                    <i class="fa-solid fa-receipt mr-1 text-gray-400"></i>${s.invoiceNumber}
                </td>
                <td class="p-3 text-sm text-gray-600">${formatDate(s.dateTime)}</td>
                <td class="p-3 text-sm text-gray-800">${formatCurrency(s.totalAmount)}</td>
                <td class="p-3 text-sm text-gray-600">${formatCurrency(s.discount)}</td>
                <td class="p-3 text-right font-bold text-gray-800">${formatCurrency(s.netAmount)}</td>
                <td class="p-3 text-sm text-gray-600"><span class="px-2 py-1 bg-gray-100 rounded text-xs uppercase">${s.paymentMethod}</span></td>
            </tr>
        `;
    });
};

const generateInventoryReport = async () => {
    const allDrugs = await db.drugs.toArray();
    const allBatches = await db.batches.toArray();
    
    let totalStockValue = 0;
    let totalRetailValue = 0;
    let totalItems = 0;
    
    const inventoryData = [];

    for (let drug of allDrugs) {
        const drugBatches = allBatches.filter(b => b.drugId === drug.id && b.qty > 0);
        let totalQty = 0;
        let drugCostValue = 0;
        let drugRetailValue = 0;

        drugBatches.forEach(b => {
            totalQty += b.qty;
            drugCostValue += (b.qty * (b.costPrice || 0));
            drugRetailValue += (b.qty * (b.sellingPrice || 0));
        });

        if (totalQty > 0 || true) { // Include all drugs for complete report
            inventoryData.push({
                name: drug.brandName,
                generic: drug.genericName,
                qty: totalQty,
                costValue: drugCostValue,
                retailValue: drugRetailValue
            });
            totalStockValue += drugCostValue;
            totalRetailValue += drugRetailValue;
            totalItems++;
        }
    }

    // Update Summary
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Total Unique Items</p>
            <h2 class="text-3xl font-bold text-gray-800 mt-1">${totalItems}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Total Stock Cost Value</p>
            <h2 class="text-3xl font-bold text-blue-600 mt-1">${formatCurrency(totalStockValue)}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Est. Retail Value</p>
            <h2 class="text-3xl font-bold text-green-600 mt-1">${formatCurrency(totalRetailValue)}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Current Inventory Stock';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Drug Name</th>
            <th class="p-3 font-medium border-b border-gray-200">Generic Name</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Total Qty</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Cost Value</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Retail Value</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(inventoryData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-gray-500">No inventory found.</td></tr>';
        return;
    }

    inventoryData.sort((a,b) => a.name.localeCompare(b.name)).forEach(item => {
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-gray-800 font-medium">${item.name}</td>
                <td class="p-3 text-gray-600 text-xs">${item.generic || '-'}</td>
                <td class="p-3 text-gray-800 text-right font-medium">${item.qty}</td>
                <td class="p-3 text-gray-600 text-right">${formatCurrency(item.costValue)}</td>
                <td class="p-3 text-green-600 text-right">${formatCurrency(item.retailValue)}</td>
            </tr>
        `;
    });
};

const generateReorderReport = async () => {
    const allDrugs = await db.drugs.toArray();
    const allBatches = await db.batches.toArray();
    const threshold = 20; // Default minimum level
    const reorderAmount = 50; // Standard reorder pack size
    
    const reorderItems = [];

    for (let drug of allDrugs) {
        const drugBatches = allBatches.filter(b => b.drugId === drug.id && b.qty > 0);
        let totalQty = 0;
        drugBatches.forEach(b => totalQty += b.qty);

        if (totalQty <= threshold) {
            reorderItems.push({
                name: drug.brandName,
                supplier: drug.supplierId ? (await db.suppliers.get(drug.supplierId))?.name || 'Unknown' : 'Unknown',
                qty: totalQty,
                required: (threshold - totalQty) + reorderAmount
            });
        }
    }

    // Update Summary
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Items to Reorder</p>
            <h2 class="text-3xl font-bold text-orange-600 mt-1">${reorderItems.length}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Out of Stock (0 qty)</p>
            <h2 class="text-3xl font-bold text-red-600 mt-1">${reorderItems.filter(i => i.qty === 0).length}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Total Qty to Order</p>
            <h2 class="text-3xl font-bold text-blue-600 mt-1">${reorderItems.reduce((acc, i) => acc + i.required, 0)}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Reorder & Purchase Plan';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Drug Name</th>
            <th class="p-3 font-medium border-b border-gray-200">Primary Supplier</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Current Qty</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Required Qty</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(reorderItems.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="p-4 text-center text-gray-500">No items need reordering.</td></tr>';
        return;
    }

    reorderItems.sort((a,b) => a.qty - b.qty).forEach(item => {
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="p-3 text-gray-800 font-medium">${item.name}</td>
                <td class="p-3 text-gray-600">${item.supplier}</td>
                <td class="p-3 text-gray-800 text-right font-medium ${item.qty === 0 ? 'text-red-600' : ''}">${item.qty}</td>
                <td class="p-3 text-blue-600 text-right font-bold">${item.required}</td>
            </tr>
        `;
    });
};

const generateExpiryReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allBatches = await db.batches.toArray();
    
    const expiringBatches = [];
    for(let b of allBatches) {
        const expDate = new Date(b.expiryDate);
        if(expDate >= startDate && expDate <= endDate && b.qty > 0) {
            const drug = await db.drugs.get(b.drugId);
            expiringBatches.push({
                drugName: drug ? drug.brandName : 'Unknown',
                batchNumber: b.batchNumber,
                expiryDate: b.expiryDate,
                qty: b.qty,
                costPrice: b.costPrice || 0,
                isExpired: expDate < new Date()
            });
        }
    }

    const expiredValue = expiringBatches.filter(b => b.isExpired).reduce((sum, b) => sum + (b.qty * b.costPrice), 0);

    // Update Summary
    document.getElementById('report-summary-container').innerHTML = `
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Batches in Range</p>
            <h2 class="text-3xl font-bold text-gray-800 mt-1">${expiringBatches.length}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Already Expired (Qty)</p>
            <h2 class="text-3xl font-bold text-red-600 mt-1">${expiringBatches.filter(b => b.isExpired).reduce((s, b) => s + b.qty, 0)}</h2>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm">
            <p class="text-sm text-gray-500 font-medium">Expired Value Loss</p>
            <h2 class="text-3xl font-bold text-orange-600 mt-1">${formatCurrency(expiredValue)}</h2>
        </div>
    `;

    document.getElementById('report-table-title').innerText = 'Expiry Report';
    document.getElementById('report-table-head').innerHTML = `
        <tr class="text-xs uppercase text-gray-500 tracking-wider">
            <th class="p-3 font-medium border-b border-gray-200">Drug Name</th>
            <th class="p-3 font-medium border-b border-gray-200">Batch Number</th>
            <th class="p-3 font-medium border-b border-gray-200">Expiry Date</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Stock Qty</th>
            <th class="p-3 font-medium border-b border-gray-200 text-right">Loss Value</th>
        </tr>
    `;

    const tbody = document.getElementById('report-table-body');
    tbody.innerHTML = '';
    
    if(expiringBatches.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-gray-500">No expiring batches found.</td></tr>';
        return;
    }

    expiringBatches.sort((a,b) => new Date(a.expiryDate) - new Date(b.expiryDate)).forEach(item => {
        tbody.innerHTML += `
            <tr class="hover:bg-gray-50 ${item.isExpired ? 'bg-red-50/30' : ''}">
                <td class="p-3 text-gray-800 font-medium">${item.drugName}</td>
                <td class="p-3 text-gray-600">${item.batchNumber}</td>
                <td class="p-3 text-gray-800 ${item.isExpired ? 'text-red-600 font-bold' : ''}">${formatDate(item.expiryDate).split(' ')[0]}</td>
                <td class="p-3 text-right font-bold">${item.qty}</td>
                <td class="p-3 text-right text-gray-600">${item.isExpired ? formatCurrency(item.qty * item.costPrice) : '-'}</td>
            </tr>
        `;
    });
};

const generatePurchasesReport = async () => {
    const { startDate, endDate } = getReportDateRange();
    const allGRNs = await db.grns.toArray();
    
    const filteredGRNs = allGRNs.filter(g => {
        const gDate = new Date(g.date);
        return gDate >= startDate && gDate <= endDate && g.status === 'completed';
