    prescriptions.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(p => {
        container.innerHTML += `
            <div class="p-3 border border-gray-200 rounded bg-white shadow-sm flex flex-col gap-2">
                <div class="flex justify-between items-start">
                    <div class="text-sm font-medium text-gray-800"><i class="fa-solid fa-user-doctor text-blue-500 mr-1"></i> ${p.doctorName}</div>
                    <div class="text-xs text-gray-500">${p.date}</div>
                </div>
                <div class="text-xs text-gray-600 bg-gray-50 p-2 rounded border border-gray-100">${p.notes || 'No notes provided'}</div>
                ${p.imageString ? `
                    <button type="button" onclick="viewImage('${p.imageString}')" class="text-left text-blue-600 text-xs hover:underline mt-1">
                        <i class="fa-solid fa-image"></i> View Scanned Copy
                    </button>
                ` : ''}
            </div>
